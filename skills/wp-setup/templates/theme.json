{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "defaultDuotone": false,
      "palette": [
        { "slug": "base",          "color": "#ffffff", "name": "Base" },
        { "slug": "surface",       "color": "#f6f4f0", "name": "Surface" },
        { "slug": "surface-2",     "color": "#1c1a17", "name": "Surface Deep" },
        { "slug": "contrast",      "color": "#1c1a17", "name": "Contrast" },
        { "slug": "contrast-2",    "color": "#5c564d", "name": "Contrast Muted" },
        { "slug": "primary",       "color": "#1f5d50", "name": "Primary" },
        { "slug": "primary-hover", "color": "#16463c", "name": "Primary Hover" },
        { "slug": "secondary",     "color": "#2b4a6f", "name": "Secondary" },
        { "slug": "accent",        "color": "#b85c30", "name": "Accent" },
        { "slug": "border",        "color": "#e6e1d8", "name": "Border" }
      ],
      "gradients": [
        {
          "slug": "brand-fade",
          "name": "Brand Fade",
          "gradient": "linear-gradient(135deg, var(--wp--preset--color--primary) 0%, var(--wp--preset--color--primary-hover) 100%)"
        },
        {
          "slug": "warm-surface",
          "name": "Warm Surface",
          "gradient": "linear-gradient(180deg, var(--wp--preset--color--base) 0%, var(--wp--preset--color--surface) 100%)"
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "fluid": true,
      "lineHeight": true,
      "writingMode": false,
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "Geist, system-ui, -apple-system, 'Segoe UI', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Geist",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./fonts/geist/Geist-Variable.woff2"]
            }
          ]
        },
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "Inter, system-ui, -apple-system, 'Segoe UI', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./fonts/inter/Inter-Variable.woff2"]
            }
          ]
        },
        {
          "slug": "mono",
          "name": "Mono",
          "fontFamily": "'Geist Mono', ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, monospace",
          "fontFace": [
            {
              "fontFamily": "Geist Mono",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./fonts/geist-mono/GeistMono-Variable.woff2"]
            }
          ]
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "clamp(0.875rem, 0.85rem + 0.125vw, 1rem)",
          "fluid": false
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "clamp(1rem, 0.95rem + 0.25vw, 1.125rem)",
          "fluid": false
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "clamp(1.25rem, 1.15rem + 0.5vw, 1.5rem)",
          "fluid": false
        },
        {
          "slug": "x-large",
          "name": "Extra Large",
          "size": "clamp(1.75rem, 1.5rem + 1.25vw, 2.25rem)",
          "fluid": false
        },
        {
          "slug": "xx-large",
          "name": "Extra Extra Large",
          "size": "clamp(2.25rem, 1.85rem + 2vw, 3.25rem)",
          "fluid": false
        },
        {
          "slug": "huge",
          "name": "Huge",
          "size": "clamp(2.75rem, 2rem + 3.75vw, 4.75rem)",
          "fluid": false
        }
      ]
    },
    "spacing": {
      "customSpacingSize": false,
      "units": ["px", "em", "rem", "%", "vw", "vh"],
      "spacingScale": { "steps": 0 },
      "spacingSizes": [
        { "slug": "10", "name": "1 — 2XS", "size": "clamp(0.25rem, 0.2rem + 0.25vw, 0.5rem)" },
        { "slug": "20", "name": "2 — XS",  "size": "clamp(0.5rem, 0.4rem + 0.5vw, 0.75rem)" },
        { "slug": "30", "name": "3 — S",   "size": "clamp(0.75rem, 0.6rem + 0.75vw, 1.25rem)" },
        { "slug": "40", "name": "4 — M",   "size": "clamp(1.25rem, 1rem + 1.25vw, 2rem)" },
        { "slug": "50", "name": "5 — L",   "size": "clamp(2rem, 1.5rem + 2.5vw, 3.5rem)" },
        { "slug": "60", "name": "6 — XL",  "size": "clamp(3.5rem, 2.5rem + 5vw, 6rem)" },
        { "slug": "70", "name": "7 — XXL", "size": "clamp(5rem, 3.5rem + 7.5vw, 9rem)" },
        { "slug": "80", "name": "8 — 3XL", "size": "clamp(7rem, 5rem + 10vw, 12rem)" }
      ]
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        { "slug": "sm", "name": "Small",  "shadow": "0 1px 2px rgba(28,26,23,0.06), 0 1px 3px rgba(28,26,23,0.05)" },
        { "slug": "md", "name": "Medium", "shadow": "0 4px 16px rgba(28,26,23,0.08)" },
        { "slug": "lg", "name": "Large",  "shadow": "0 12px 40px rgba(28,26,23,0.12)" }
      ]
    },
    "layout": {
      "contentSize": "768px",
      "wideSize": "1200px"
    },
    "border": {
      "customColor": false,
      "customRadius": false,
      "customStyle": false,
      "customWidth": false
    },
    "custom": {
      "radius": {
        "sm": "4px",
        "md": "8px",
        "lg": "16px",
        "pill": "999px"
      },
      "shadow": {
        "sm": "0 1px 2px rgba(28,26,23,0.06), 0 1px 3px rgba(28,26,23,0.05)",
        "md": "0 4px 16px rgba(28,26,23,0.08)",
        "lg": "0 12px 40px rgba(28,26,23,0.12)"
      },
      "aspectRatio": {
        "square": "1",
        "video": "16 / 9",
        "portrait": "3 / 4"
      },
      "accentOnDark": "#d98a5e"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--40)",
      "padding": {
        "top": "0",
        "right": "var(--wp--preset--spacing--40)",
        "bottom": "0",
        "left": "var(--wp--preset--spacing--40)"
      }
    },
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        ":hover": {
          "color": { "text": "var(--wp--preset--color--primary-hover)" }
        }
      },
      "heading": {
        "color": { "text": "var(--wp--preset--color--contrast)" },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "lineHeight": "1.15",
          "letterSpacing": "-0.01em"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--huge)",
          "lineHeight": "1.05",
          "letterSpacing": "-0.02em"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "lineHeight": "1.1",
          "letterSpacing": "-0.015em"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "lineHeight": "1.15"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)",
          "lineHeight": "1.2"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)",
          "lineHeight": "1.3"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)",
          "lineHeight": "1.4",
          "textTransform": "uppercase",
          "letterSpacing": "0.06em"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "border": { "radius": "var(--wp--custom--radius--md)" },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--20)",
            "bottom": "var(--wp--preset--spacing--20)",
            "left": "var(--wp--preset--spacing--40)",
            "right": "var(--wp--preset--spacing--40)"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontWeight": "600",
          "fontSize": "var(--wp--preset--font-size--medium)"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--primary-hover)",
            "text": "var(--wp--preset--color--base)"
          }
        },
        ":focus": {
          "color": {
            "background": "var(--wp--preset--color--primary-hover)",
            "text": "var(--wp--preset--color--base)"
          }
        },
        ":active": {
          "color": {
            "background": "var(--wp--preset--color--primary-hover)",
            "text": "var(--wp--preset--color--base)"
          }
        }
      }
    }
  }
}
