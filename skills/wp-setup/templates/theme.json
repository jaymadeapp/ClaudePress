{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "custom": false,
      "customDuotone": true,
      "customGradient": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "defaultDuotone": false,
      "palette": [
        { "slug": "base",          "color": "#f1eae0", "name": "Base" },
        { "slug": "surface",       "color": "#f7f2e9", "name": "Surface" },
        { "slug": "surface-2",     "color": "#2c271f", "name": "Surface Deep" },
        { "slug": "contrast",      "color": "#2c271f", "name": "Contrast" },
        { "slug": "contrast-2",    "color": "#5d564a", "name": "Contrast Muted" },
        { "slug": "primary",       "color": "#3f4a2e", "name": "Primary" },
        { "slug": "primary-hover", "color": "#313a23", "name": "Primary Hover" },
        { "slug": "secondary",     "color": "#7d8a5c", "name": "Secondary" },
        { "slug": "accent",        "color": "#965729", "name": "Accent" },
        { "slug": "border",        "color": "#e3d9c8", "name": "Border" }
      ],
      "gradients": [
        {
          "slug": "clay",
          "name": "Clay",
          "gradient": "linear-gradient(150deg, #c98a52 0%, #a85f33 100%)"
        },
        {
          "slug": "sand-fade",
          "name": "Sand Fade",
          "gradient": "linear-gradient(180deg, var(--wp--preset--color--base) 0%, var(--wp--preset--color--surface) 100%)"
        }
      ],
      "duotone": [
        {
          "slug": "clay",
          "name": "Clay",
          "colors": ["#2c271f", "#c98a52"]
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "defaultFontSizes": false,
      "fluid": true,
      "lineHeight": true,
      "writingMode": false,
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "'Hanken Grotesk', system-ui, -apple-system, 'Segoe UI', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Hanken Grotesk",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./fonts/hanken-grotesk/HankenGrotesk-Variable.woff2"]
            }
          ]
        },
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "'Hanken Grotesk', system-ui, -apple-system, 'Segoe UI', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Hanken Grotesk",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./fonts/hanken-grotesk/HankenGrotesk-Variable.woff2"]
            }
          ]
        },
        {
          "slug": "display",
          "name": "Display",
          "fontFamily": "Fraunces, Georgia, 'Times New Roman', serif",
          "fontFace": [
            {
              "fontFamily": "Fraunces",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./fonts/fraunces/Fraunces-Variable.woff2"]
            },
            {
              "fontFamily": "Fraunces",
              "fontWeight": "100 900",
              "fontStyle": "italic",
              "fontDisplay": "swap",
              "src": ["file:./fonts/fraunces/Fraunces-Italic-Variable.woff2"]
            }
          ]
        },
        {
          "slug": "mono",
          "name": "Mono",
          "fontFamily": "'Geist Mono', ui-monospace, 'SF Mono', 'Cascadia Code', Menlo, monospace",
          "fontFace": [
            {
              "fontFamily": "Geist Mono",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./fonts/geist-mono/GeistMono-Variable.woff2"]
            }
          ]
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "clamp(0.875rem, 0.85rem + 0.125vw, 1rem)",
          "fluid": false
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "clamp(1.0625rem, 1rem + 0.25vw, 1.1875rem)",
          "fluid": false
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "clamp(1.25rem, 1.1rem + 0.6vw, 1.625rem)",
          "fluid": false
        },
        {
          "slug": "x-large",
          "name": "Extra Large",
          "size": "clamp(1.75rem, 1.45rem + 1.4vw, 2.5rem)",
          "fluid": false
        },
        {
          "slug": "xx-large",
          "name": "Extra Extra Large",
          "size": "clamp(2.25rem, 1.75rem + 2.4vw, 3.75rem)",
          "fluid": false
        },
        {
          "slug": "huge",
          "name": "Huge",
          "size": "clamp(2.75rem, 2rem + 4.5vw, 5rem)",
          "fluid": false
        }
      ]
    },
    "spacing": {
      "customSpacingSize": false,
      "defaultSpacingSizes": false,
      "units": ["px", "em", "rem", "%", "vw", "vh"],
      "spacingScale": { "steps": 0 },
      "spacingSizes": [
        { "slug": "10", "name": "1 — 2XS", "size": "clamp(0.25rem, 0.2rem + 0.25vw, 0.5rem)" },
        { "slug": "20", "name": "2 — XS",  "size": "clamp(0.5rem, 0.4rem + 0.5vw, 0.875rem)" },
        { "slug": "30", "name": "3 — S",   "size": "clamp(0.875rem, 0.7rem + 0.85vw, 1.5rem)" },
        { "slug": "40", "name": "4 — M",   "size": "clamp(1.5rem, 1.15rem + 1.5vw, 2.5rem)" },
        { "slug": "50", "name": "5 — L",   "size": "clamp(2.25rem, 1.7rem + 2.75vw, 4rem)" },
        { "slug": "60", "name": "6 — XL",  "size": "clamp(3.5rem, 2.5rem + 5vw, 6.5rem)" },
        { "slug": "70", "name": "7 — XXL", "size": "clamp(5rem, 3.5rem + 7.5vw, 9.5rem)" },
        { "slug": "80", "name": "8 — 3XL", "size": "clamp(7rem, 5rem + 10vw, 13rem)" }
      ]
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        { "slug": "sm", "name": "Small",  "shadow": "0 2px 8px rgba(60,40,25,.06)" },
        { "slug": "md", "name": "Medium", "shadow": "0 10px 30px -8px rgba(80,55,30,.14)" },
        { "slug": "lg", "name": "Large",  "shadow": "0 26px 60px -20px rgba(80,55,30,.20)" }
      ]
    },
    "layout": {
      "contentSize": "780px",
      "wideSize": "1240px"
    },
    "border": {
      "customColor": false,
      "customRadius": false,
      "customStyle": false,
      "customWidth": false
    },
    "custom": {
      "color": {
        "sand-2": "#e3d3bd",
        "sage-tint": "#d8e0cb",
        "clay-tint": "#ecd3c2",
        "on-primary": "var(--wp--preset--color--base)",
        "on-accent": "var(--wp--preset--color--base)",
        "on-surface-2": "var(--wp--preset--color--base)",
        "accent-ink": "var(--wp--preset--color--accent)",
        "primary-ink": "var(--wp--preset--color--primary)"
      },
      "radius": {
        "sm": "8px",
        "md": "14px",
        "lg": "22px",
        "xl": "32px",
        "pill": "999px"
      },
      "blob": {
        "blob1": "62% 38% 47% 53% / 45% 54% 46% 55%",
        "blob2": "58% 42% 51% 49% / 52% 47% 53% 48%",
        "blob3": "60% 40% 52% 48% / 48% 56% 44% 52%"
      },
      "shadow": {
        "sm": "0 2px 8px rgba(60,40,25,.06)",
        "md": "0 10px 30px -8px rgba(80,55,30,.14)",
        "lg": "0 26px 60px -20px rgba(80,55,30,.20)"
      },
      "aspectRatio": {
        "square": "1",
        "video": "16 / 9",
        "portrait": "3 / 4"
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--50)",
      "padding": {
        "top": "0",
        "right": "var(--wp--preset--spacing--40)",
        "bottom": "0",
        "left": "var(--wp--preset--spacing--40)"
      }
    },
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        ":hover": {
          "color": { "text": "var(--wp--preset--color--primary-hover)" }
        }
      },
      "heading": {
        "color": { "text": "var(--wp--preset--color--contrast)" },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "lineHeight": "1.15",
          "letterSpacing": "-0.01em"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--huge)",
          "fontWeight": "700",
          "lineHeight": "1.05",
          "letterSpacing": "-0.02em"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "fontWeight": "600",
          "lineHeight": "1.1",
          "letterSpacing": "-0.015em"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "fontWeight": "600",
          "lineHeight": "1.15"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "600",
          "lineHeight": "1.2"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": "600",
          "lineHeight": "1.4",
          "textTransform": "uppercase",
          "letterSpacing": "0.06em"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "border": { "radius": "var(--wp--custom--radius--pill)" },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--30)",
            "bottom": "var(--wp--preset--spacing--30)",
            "left": "var(--wp--preset--spacing--50)",
            "right": "var(--wp--preset--spacing--50)"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "600",
          "fontSize": "var(--wp--preset--font-size--medium)"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--primary-hover)",
            "text": "var(--wp--preset--color--base)"
          }
        },
        ":focus": {
          "color": {
            "background": "var(--wp--preset--color--primary-hover)",
            "text": "var(--wp--preset--color--base)"
          }
        },
        ":active": {
          "color": {
            "background": "var(--wp--preset--color--primary-hover)",
            "text": "var(--wp--preset--color--base)"
          }
        }
      }
    },
    "blocks": {
      "woocommerce/product-price": {
        "color": { "text": "var:preset|color|primary" },
        "typography": { "fontWeight": "700" }
      },
      "woocommerce/product-rating": {
        "color": { "text": "var:preset|color|accent" }
      },
      "woocommerce/product-sale-badge": {
        "color": {
          "background": "var:preset|color|accent",
          "text": "var:preset|color|base"
        },
        "border": { "radius": "var:custom|radius|pill" }
      },
      "woocommerce/product-button": {
        "color": {
          "background": "var:preset|color|primary",
          "text": "var:preset|color|base"
        },
        "border": { "radius": "var:custom|radius|pill" }
      }
    }
  }
}
