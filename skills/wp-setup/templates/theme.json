{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "defaultDuotone": false,
      "palette": [
        { "slug": "base",      "color": "#ffffff", "name": "Base" },
        { "slug": "contrast",  "color": "#111111", "name": "Contrast" },
        { "slug": "primary",   "color": "#1d4ed8", "name": "Primary" },
        { "slug": "secondary", "color": "#0f766e", "name": "Secondary" },
        { "slug": "accent",    "color": "#f59e0b", "name": "Accent" },
        { "slug": "neutral",   "color": "#6b7280", "name": "Neutral" },
        { "slug": "muted",     "color": "#f3f4f6", "name": "Muted" }
      ]
    },
    "typography": {
      "customFontSize": false,
      "fluid": true,
      "lineHeight": true,
      "writingMode": false,
      "fontFamilies": [
        {
          "slug": "sans",
          "name": "Sans",
          "fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
        },
        {
          "slug": "serif",
          "name": "Serif",
          "fontFamily": "Georgia, Cambria, 'Times New Roman', Times, serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "1rem",
          "fluid": { "min": "0.875rem", "max": "1rem" }
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "1.125rem",
          "fluid": { "min": "1rem", "max": "1.125rem" }
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "1.5rem",
          "fluid": { "min": "1.25rem", "max": "1.5rem" }
        },
        {
          "slug": "x-large",
          "name": "Extra Large",
          "size": "clamp(2rem, 1.5rem + 2.5vw, 3rem)"
        },
        {
          "slug": "xx-large",
          "name": "Huge",
          "size": "clamp(2.75rem, 2rem + 3.75vw, 4.5rem)"
        }
      ]
    },
    "spacing": {
      "customSpacingSize": false,
      "units": ["px", "em", "rem", "%", "vw", "vh"],
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        { "slug": "20", "name": "1 — XS",  "size": "clamp(0.5rem, 0.4rem + 0.5vw, 0.75rem)" },
        { "slug": "30", "name": "2 — S",   "size": "clamp(0.75rem, 0.6rem + 0.75vw, 1.25rem)" },
        { "slug": "40", "name": "3 — M",   "size": "clamp(1.25rem, 1rem + 1.25vw, 2rem)" },
        { "slug": "50", "name": "4 — L",   "size": "clamp(2rem, 1.5rem + 2.5vw, 3.5rem)" },
        { "slug": "60", "name": "5 — XL",  "size": "clamp(3.5rem, 2.5rem + 5vw, 6rem)" },
        { "slug": "70", "name": "6 — XXL", "size": "clamp(5rem, 3.5rem + 7.5vw, 9rem)" }
      ]
    },
    "layout": {
      "contentSize": "768px",
      "wideSize": "1200px"
    },
    "border": {
      "customColor": false,
      "customRadius": false,
      "customStyle": false,
      "customWidth": false
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--40)",
      "padding": {
        "top": "0",
        "right": "var(--wp--preset--spacing--40)",
        "bottom": "0",
        "left": "var(--wp--preset--spacing--40)"
      }
    },
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" }
      },
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--sans)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      }
    }
  }
}
