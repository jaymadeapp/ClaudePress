/* ─────────────────────────────────────────────────────────────────────────
 * Loamkit design tokens — Terra (Tailwind v4 @theme mirror)
 * Mirrors theme.json so Tailwind utilities and WP presets never drift.
 * Slugs match settings.color.palette / typography / spacing / custom exactly.
 * The single source of truth is theme.json; keep these in sync.
 * ───────────────────────────────────────────────────────────────────────── */
@theme {
  /* Colors → utilities like bg-base, text-primary, border-border */
  --color-base: #f1eae0;
  --color-surface: #f7f2e9;
  --color-surface-2: #2c271f;
  --color-contrast: #2c271f;
  --color-contrast-2: #5d564a;
  --color-primary: #3f4a2e;
  --color-primary-hover: #313a23;
  --color-secondary: #7d8a5c;
  --color-accent: #965729;
  --color-border: #e3d9c8;

  /* Warm tints used by patterns / image-block fills */
  --color-sand-2: #e3d3bd;
  --color-sage-tint: #d8e0cb;
  --color-clay-tint: #ecd3c2;

  /* Fonts → font-heading, font-body, font-display, font-mono */
  --font-heading: "Hanken Grotesk", system-ui, -apple-system, "Segoe UI", sans-serif;
  --font-body: "Hanken Grotesk", system-ui, -apple-system, "Segoe UI", sans-serif;
  --font-display: Fraunces, Georgia, "Times New Roman", serif;
  --font-mono: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace;

  /* Fluid type scale → text-small … text-huge */
  --text-small: clamp(0.875rem, 0.85rem + 0.125vw, 1rem);
  --text-medium: clamp(1.0625rem, 1rem + 0.25vw, 1.1875rem);
  --text-large: clamp(1.25rem, 1.1rem + 0.6vw, 1.625rem);
  --text-x-large: clamp(1.75rem, 1.45rem + 1.4vw, 2.5rem);
  --text-xx-large: clamp(2.25rem, 1.75rem + 2.4vw, 3.75rem);
  --text-huge: clamp(2.75rem, 2rem + 4.5vw, 5rem);

  /* Fluid spacing → p-10 … p-80 (matches spacingSizes slugs) */
  --spacing-10: clamp(0.25rem, 0.2rem + 0.25vw, 0.5rem);
  --spacing-20: clamp(0.5rem, 0.4rem + 0.5vw, 0.875rem);
  --spacing-30: clamp(0.875rem, 0.7rem + 0.85vw, 1.5rem);
  --spacing-40: clamp(1.5rem, 1.15rem + 1.5vw, 2.5rem);
  --spacing-50: clamp(2.25rem, 1.7rem + 2.75vw, 4rem);
  --spacing-60: clamp(3.5rem, 2.5rem + 5vw, 6.5rem);
  --spacing-70: clamp(5rem, 3.5rem + 7.5vw, 9.5rem);
  --spacing-80: clamp(7rem, 5rem + 10vw, 13rem);

  /* Radius → rounded-sm … rounded-pill (Terra is soft / rounded) */
  --radius-sm: 8px;
  --radius-md: 14px;
  --radius-lg: 22px;
  --radius-xl: 32px;
  --radius-pill: 999px;

  /* Shadows → shadow-sm … shadow-lg (soft warm, never black) */
  --shadow-sm: 0 2px 8px rgba(60, 40, 25, .06);
  --shadow-md: 0 10px 30px -8px rgba(80, 55, 30, .14);
  --shadow-lg: 0 26px 60px -20px rgba(80, 55, 30, .20);
}

/* ─────────────────────────────────────────────────────────────────────────
 * Token-driven base niceties — safe 2026 baseline, progressive enhancement.
 * Everything below is driven by the WP preset vars emitted from theme.json.
 * ───────────────────────────────────────────────────────────────────────── */

/* Global overflow guard — keep a single offender (the hero blob, a long URL)
 * from spawning a mobile horizontal scrollbar. Must include the document element
 * because horizontal scroll is measured on <html>; overflow-x:clip (unlike
 * hidden) creates no scroll container, so the sticky header still works. */
:where(html, body) {
  overflow-x: clip;
}

img, svg, video, figure {
  max-width: 100%;
}

/* Section eyebrow (mono small-caps kicker) contrast. The patterns emit eyebrows
 * as `secondary` (sage), which fails WCAG AA at small size on the warm light
 * surfaces (~3.1:1) and badly on the primary band (~2.5:1). Re-map the eyebrow
 * signature (the secondary + mono classes the patterns set) to a token that
 * passes on each surface: muted contrast-2 on the default light sections (~6:1)
 * and a light sage-tint on the dark inverse/brand/contrast bands (~7–11:1). Body
 * copy is untouched (it isn't mono+secondary); !important beats WP's has-*-color
 * utility. Keep section eyebrows on these tokens, never on bare `secondary`. */
.has-secondary-color.has-mono-font-family {
  color: var(--wp--preset--color--contrast-2) !important;
}

.has-primary-background-color .has-secondary-color.has-mono-font-family,
.has-surface-2-background-color .has-secondary-color.has-mono-font-family,
.has-contrast-background-color .has-secondary-color.has-mono-font-family {
  color: var(--wp--custom--color--sage-tint, #d8e0cb) !important;
}

/* ── Theme-agnostic text-on-band tokens ──────────────────────────────────────
 * Patterns paint the light `base` role as text onto bold/dark colored bands
 * (primary CTA, surface-2 ink) and as button labels on primary/accent fills. That
 * only stays legible while `base` is light AND every accent is dark enough for it.
 * A dark direction (Atlas: dark `base`) or a light-accent direction (Pulse yellow,
 * Aurora cyan) breaks that. Each direction defines on-primary / on-accent /
 * on-surface-2 (the legible text colour for that band, default `base`); these rules
 * re-point band + button text at those tokens so every direction stays legible with
 * zero per-pattern edits. */
.wp-element-button.has-primary-background-color {
  color: var(--wp--custom--color--on-primary, var(--wp--preset--color--base)) !important;
}

.wp-element-button.has-accent-background-color {
  color: var(--wp--custom--color--on-accent, var(--wp--preset--color--base)) !important;
}

.has-primary-background-color {
  color: var(--wp--custom--color--on-primary, var(--wp--preset--color--base));
}

.has-surface-2-background-color,
.has-contrast-background-color {
  color: var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base));
}

/* Inside those bands, re-point the explicit light-text role (the `base`/`contrast`
 * text the patterns set) at the band token. Needs class specificity + !important to
 * beat WP's `.has-base-color { … !important }` utility. Buttons keep their own
 * on-accent/on-primary; the mono eyebrow keeps its sage-tint remap; accent words
 * (the italic display accent) keep their accent colour. */
.has-primary-background-color .has-base-color:not(.wp-element-button),
.has-primary-background-color .has-contrast-color:not(.wp-element-button) {
  color: var(--wp--custom--color--on-primary, var(--wp--preset--color--base)) !important;
}

.has-surface-2-background-color .has-base-color:not(.wp-element-button),
.has-surface-2-background-color .has-contrast-color:not(.wp-element-button),
.has-contrast-background-color .has-base-color:not(.wp-element-button),
.has-contrast-background-color .has-contrast-color:not(.wp-element-button) {
  color: var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base)) !important;
}

/* Body copy inside the dark bands uses `surface` as a muted light tone. On a dark
 * direction (Atlas) raw `surface` is too dark on a primary / surface-2 card, so the
 * paragraph vanishes while the heading (re-pointed above) stays. Re-point body copy
 * at the band token too, held at 82% for the heading→body hierarchy. On Terra the
 * band token === base (light) so this is a no-op tonal nudge. */
.has-primary-background-color .has-surface-color:not(.wp-element-button) {
  color: color-mix(in srgb, var(--wp--custom--color--on-primary, var(--wp--preset--color--base)) 82%, transparent) !important;
}
.has-surface-2-background-color .has-surface-color:not(.wp-element-button),
.has-contrast-background-color .has-surface-color:not(.wp-element-button) {
  color: color-mix(in srgb, var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base)) 82%, transparent) !important;
}

/* CTA inverse pill (cta-band): an on-primary fill with primary-coloured text. Set
 * here (not inline) because WordPress regenerates a core/button's style attribute
 * from block attrs and drops hand-written inline colour. on-primary is legible on
 * the primary band by definition, so the pill always contrasts the band — even on
 * Linen where accent === primary. Defaults keep Terra a cream pill with sage text. */
.cp-cta-pill.wp-element-button {
  background-color: var(--wp--custom--color--on-primary, var(--wp--preset--color--base)) !important;
  color: var(--wp--preset--color--primary) !important;
}
.cp-cta-pill:hover,
.cp-cta-pill:focus-visible {
  opacity: 0.9;
}

/* Brand colour used AS TEXT (links, inline accents) on light grounds uses the legible
 * "ink" variant. A direction whose accent/primary is light (Pulse yellow, Aurora cyan)
 * would otherwise render links and accent words below WCAG; the ink token is a
 * darkened-to-AA version. Defaults to accent/primary (Terra & dark Atlas unchanged);
 * button fills keep their own colour. */
:where(p, a, li, span, h1, h2, h3, h4, h5, h6).has-accent-color:not(.wp-element-button) {
  color: var(--wp--custom--color--accent-ink, var(--wp--preset--color--accent)) !important;
}
:where(p, a, li, span, h1, h2, h3, h4, h5, h6).has-primary-color:not(.wp-element-button) {
  color: var(--wp--custom--color--primary-ink, var(--wp--preset--color--primary)) !important;
}

/* Ghost / text buttons (coloured label, no fill — e.g. "Read our story →") also need
 * the ink variant; filled buttons carry `has-background` and keep their on-* label. */
.wp-element-button.has-primary-color:not(.has-background) {
  color: var(--wp--custom--color--primary-ink, var(--wp--preset--color--primary)) !important;
}
.wp-element-button.has-accent-color:not(.has-background) {
  color: var(--wp--custom--color--accent-ink, var(--wp--preset--color--accent)) !important;
}

/* Sage <main> content layout (Blade page/post templates). Without this, default-
 * aligned content — the page title, plain headings and paragraphs — bleeds to the
 * viewport edge while full-bleed pattern sections respect their inset. Give <main>
 * the shared gutter, constrain default content to the readable content-size
 * (alignwide → wide-size), and let .alignfull break back out to the viewport edge.
 * Mirrors a block theme's constrained layout for the classic Blade main.
 * (WooCommerce uses its own .cp-store container, so .site-main is untouched.) */
main.main {
  padding-inline: var(--wp--preset--spacing--40);
}

/* Default + wide content aligns to the wide-size container (~the brand line) so
 * page titles, headings and intro copy line up with the full-bleed pattern
 * sections, the header brand and the footer — not centered or bled to the edge.
 * (Long-form prose lives inside the measure-capped patterns; default page intros
 * are short, so a wide column reads fine here.) */
main.main > :where(:not(.alignfull)) {
  max-width: var(--wp--style--global--wide-size, 1240px);
  margin-inline: auto;
}

main.main > .alignfull {
  max-width: none;
  margin-inline: calc(-1 * var(--wp--preset--spacing--40));
}

/* Keyboard focus ring in brand color (mouse clicks stay clean) */
:focus-visible {
  outline: 2px solid var(--wp--preset--color--primary, #3f4a2e);
  outline-offset: 2px;
  border-radius: var(--wp--custom--radius--sm, 8px);
}

/* Branded selection — warm clay on sand */
::selection {
  background-color: var(--wp--preset--color--accent, #965729);
  color: var(--wp--preset--color--base, #f1eae0);
}

/* Tidier headline and paragraph wrapping + comfortable measure */
h1, h2 {
  text-wrap: balance;
}

p {
  text-wrap: pretty;
  max-width: 66ch;
}

/* Rare full-bleed-text opt-out — uncap measure for prose meant to run wide */
.cp-measure-full p {
  max-width: none;
}

/* Crisp display cut — Fraunces high-contrast display optical size for the
 * display/accent role (vs. the muddy text grade). The real italic face is
 * bundled, so <em class="has-display-font-family"> renders true italic. */
.has-display-font-family {
  font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;
}

/* Smooth in-page scroll, but never fight reduced-motion users */
@media (prefers-reduced-motion: no-preference) {
  html {
    scroll-behavior: smooth;
  }
}

/* Readable link underlines */
a {
  text-underline-offset: 0.15em;
  text-decoration-thickness: from-font;
}

/* Container-query ready: opt a wrapper in with .cq, then use @container in CSS
 * or the editor. Left as a no-op utility so layouts can progressively enhance. */
.cq {
  container-type: inline-size;
}

/* ─────────────────────────────────────────────────────────────────────────
 * Terra organic shapes — blob radii from settings.custom.blob
 * ───────────────────────────────────────────────────────────────────────── */
.cp-blob {
  border-radius: var(--wp--custom--blob--blob1, 62% 38% 47% 53% / 45% 54% 46% 55%);
}

.cp-blob-2 {
  border-radius: var(--wp--custom--blob--blob2, 58% 42% 51% 49% / 52% 47% 53% 48%);
}

.cp-blob-3 {
  border-radius: var(--wp--custom--blob--blob3, 60% 40% 52% 48% / 48% 56% 44% 52%);
}

/* Mask an image into an organic blob shape (object-fit cover) */
.cp-blob-img {
  border-radius: var(--wp--custom--blob--blob1, 62% 38% 47% 53% / 45% 54% 46% 55%);
  overflow: hidden;
}

.cp-blob-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ─────────────────────────────────────────────────────────────────────────
 * Terra framed image — soft rounded frame with warm depth shadow
 * ───────────────────────────────────────────────────────────────────────── */
.cp-frame {
  overflow: hidden;
  border-radius: var(--wp--custom--radius--lg, 22px);
  box-shadow: var(--wp--custom--shadow--lg, 0 26px 60px -20px rgba(80, 55, 30, .20));
  background: var(--wp--preset--color--surface, #f7f2e9);
}

.cp-frame img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Framed keyless map embed (contact-split). Inherits the .cp-frame radius/shadow;
 * a warm placeholder tint shows while the iframe loads, and a gentle desaturation
 * settles the colourful map tiles into the Terra palette. */
.cp-map {
  position: relative;
  height: 100%;
  min-height: 420px;
  background: var(--wp--custom--color--sand-2, #e3d3bd);
  border: 1px solid var(--wp--preset--color--border, #e3d9c8);
}

/* Warm "loading" affordance — shows through the sand panel until the lazy map
 * iframe paints, so the column never reads as an empty box. */
.cp-map::before {
  content: "Loading map…";
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  font-family: var(--wp--preset--font-family--mono, ui-monospace, monospace);
  font-size: var(--wp--preset--font-size--small, 0.9375rem);
  letter-spacing: 0.08em;
  color: var(--wp--preset--color--contrast-2, #5d564a);
}

.cp-map iframe {
  position: relative;
  z-index: 1;
  /* Settle the colourful OSM tiles into the warm Terra palette. */
  filter: saturate(0.82) sepia(0.12) brightness(1.02);
}

/* ─────────────────────────────────────────────────────────────────────────
 * Terra scroll-reveal motion — fade + rise, staggered via --i.
 * The IntersectionObserver that adds .is-in is enqueued elsewhere (theme JS /
 * mu-plugin); this layer is CSS-only and fully gated on reduced-motion.
 * ───────────────────────────────────────────────────────────────────────── */
@media (prefers-reduced-motion: no-preference) {
  .cp-reveal {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity .7s cubic-bezier(.2, .7, .2, 1),
      transform .7s cubic-bezier(.2, .7, .2, 1);
    transition-delay: calc(var(--i, 0) * 90ms);
  }

  .cp-reveal.is-in {
    opacity: 1;
    transform: none;
  }
}

/* ─────────────────────────────────────────────────────────────────────────
 * Terra button — primary pill with a soft lift + shadow-grow on hover.
 * Token-driven; the colors/radius come from theme.json button element styles.
 * ───────────────────────────────────────────────────────────────────────── */
.wp-element-button {
  transition:
    transform .25s cubic-bezier(.2, .7, .2, 1),
    box-shadow .25s cubic-bezier(.2, .7, .2, 1);
}

@media (prefers-reduced-motion: no-preference) {
  .wp-element-button:hover {
    transform: translateY(-2px);
    box-shadow: var(--wp--custom--shadow--md, 0 10px 30px -8px rgba(80, 55, 30, .14));
  }
}

.wp-element-button:hover {
  box-shadow: var(--wp--custom--shadow--md, 0 10px 30px -8px rgba(80, 55, 30, .14));
}

/* ─────────────────────────────────────────────────────────────────────────
 * Terra site header — sticky, backdrop-blurred chrome. Transparent-to-solid:
 * a hairline border + solid backdrop fade in on scroll (data-scrolled, set by
 * the design mu-plugin). Robust without JS — it is a sticky blurred bar either
 * way. All colors/spacing/type from theme.json preset vars. Mobile uses a
 * no-JS <details> disclosure (revealed under a media query).
 * ───────────────────────────────────────────────────────────────────────── */
.cp-site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: color-mix(in srgb, var(--wp--preset--color--base, #f1eae0) 72%, transparent);
  -webkit-backdrop-filter: saturate(1.4) blur(12px);
  backdrop-filter: saturate(1.4) blur(12px);
  border-bottom: 1px solid transparent;
  transition: background .3s ease, border-color .3s ease, box-shadow .3s ease;
}

.cp-site-header[data-scrolled] {
  background: color-mix(in srgb, var(--wp--preset--color--base, #f1eae0) 90%, transparent);
  border-bottom-color: var(--wp--preset--color--border, #e3d9c8);
  box-shadow: var(--wp--custom--shadow--sm, 0 2px 8px rgba(60, 40, 25, .06));
}

.cp-site-header__inner {
  display: flex;
  align-items: center;
  gap: var(--wp--preset--spacing--30, 1.5rem);
  max-width: var(--wp--style--global--wide-size, 1240px);
  margin-inline: auto;
  padding-block: var(--wp--preset--spacing--20, 0.875rem);
  padding-inline: var(--wp--preset--spacing--40, 2.5rem);
}

.cp-site-header__brand {
  display: inline-flex;
  align-items: center;
  gap: var(--wp--preset--spacing--20, 0.875rem);
  margin-inline-end: auto;
  font-family: var(--wp--preset--font-family--heading, sans-serif);
  font-weight: 700;
  font-size: var(--wp--preset--font-size--large, 1.5rem);
  letter-spacing: -0.02em;
  color: var(--wp--preset--color--contrast, #2c271f);
  text-decoration: none;
}

.cp-site-header__mark {
  width: 1.6rem;
  height: 1.6rem;
  flex: 0 0 auto;
  background: var(--wp--preset--color--primary, #3f4a2e);
  border-radius: var(--wp--custom--blob--blob1, 62% 38% 47% 53% / 45% 54% 46% 55%);
}

/* Primary inline nav (desktop) */
.cp-site-header__nav .cp-nav {
  display: flex;
  align-items: center;
  gap: var(--wp--preset--spacing--30, 1.5rem);
  margin: 0;
  padding: 0;
  list-style: none;
}

.cp-site-header__nav .cp-nav a {
  font-family: var(--wp--preset--font-family--heading, sans-serif);
  font-weight: 500;
  font-size: var(--wp--preset--font-size--small, 1rem);
  color: var(--wp--preset--color--contrast-2, #5d564a);
  text-decoration: none;
  transition: color .2s ease;
}

.cp-site-header__nav .cp-nav a:hover,
.cp-site-header__nav .cp-nav .current-menu-item > a {
  /* primary-ink = primary darkened to AA as text on the header surface; defaults
   * to primary, so Terra is unchanged but Linen/Pulse get a legible active link. */
  color: var(--wp--custom--color--primary-ink, var(--wp--preset--color--primary, #3f4a2e));
}

/* Pill CTA — reuses the .wp-element-button token treatment for color/radius */
.cp-site-header__cta {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  padding-block: var(--wp--preset--spacing--10, 0.5rem);
  padding-inline: var(--wp--preset--spacing--30, 1.5rem);
  font-family: var(--wp--preset--font-family--heading, sans-serif);
  font-weight: 600;
  font-size: var(--wp--preset--font-size--small, 1rem);
  line-height: 1.2;
  /* on-primary keeps the label legible on a light/saturated primary; defaults to
   * base, so Terra is unchanged. */
  color: var(--wp--custom--color--on-primary, var(--wp--preset--color--base, #f1eae0));
  background: var(--wp--preset--color--primary, #3f4a2e);
  border-radius: var(--wp--custom--radius--pill, 999px);
  text-decoration: none;
}

.cp-site-header__cta:hover {
  background: var(--wp--preset--color--primary-hover, #313a23);
  color: var(--wp--custom--color--on-primary, var(--wp--preset--color--base, #f1eae0));
}

/* Mobile disclosure — hidden on desktop, replaces inline nav + CTA below 60rem */
.cp-site-header__disclosure {
  display: none;
  flex: 0 0 auto;
}

.cp-site-header__toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2.75rem;
  height: 2.75rem;
  cursor: pointer;
  list-style: none;
  border-radius: var(--wp--custom--radius--md, 14px);
}

.cp-site-header__toggle::-webkit-details-marker { display: none; }

.cp-site-header__toggle-bars,
.cp-site-header__toggle-bars::before,
.cp-site-header__toggle-bars::after {
  content: "";
  display: block;
  width: 1.25rem;
  height: 2px;
  background: var(--wp--preset--color--contrast, #2c271f);
  border-radius: var(--wp--custom--radius--pill, 999px);
  position: relative;
}

.cp-site-header__toggle-bars::before { position: absolute; top: -6px; }
.cp-site-header__toggle-bars::after  { position: absolute; top: 6px; }

.cp-site-header__drawer {
  position: absolute;
  inset-inline: 0;
  top: 100%;
  display: flex;
  flex-direction: column;
  gap: var(--wp--preset--spacing--20, 0.875rem);
  padding: var(--wp--preset--spacing--30, 1.5rem);
  background: var(--wp--preset--color--base, #f1eae0);
  border-bottom: 1px solid var(--wp--preset--color--border, #e3d9c8);
  box-shadow: var(--wp--custom--shadow--md, 0 10px 30px -8px rgba(80, 55, 30, .14));
}

.cp-nav--stacked {
  display: flex;
  flex-direction: column;
  gap: var(--wp--preset--spacing--20, 0.875rem);
  margin: 0;
  padding: 0;
  list-style: none;
}

.cp-nav--stacked a {
  font-family: var(--wp--preset--font-family--heading, sans-serif);
  font-weight: 600;
  font-size: var(--wp--preset--font-size--medium, 1.125rem);
  color: var(--wp--preset--color--contrast, #2c271f);
  text-decoration: none;
}

/* Tighten desktop nav gap in the narrow band before collapse so a 5-item menu
 * + pill CTA never overflows the 1240px header. */
@media (min-width: 50.0625rem) and (max-width: 62rem) {
  .cp-site-header__nav .cp-nav {
    gap: var(--wp--preset--spacing--20, 0.875rem);
  }
}

/* Mobile disclosure collapses at 60rem (960px) to match the store body's
 * single-column breakpoint — no 800–960px desktop-chrome / mobile-body dead zone. */
@media (max-width: 60rem) {
  .cp-site-header__nav,
  .cp-site-header__inner > .cp-site-header__cta {
    display: none;
  }

  .cp-site-header__disclosure {
    display: block;
  }
}

/* ─────────────────────────────────────────────────────────────────────────
 * Terra site footer — editorial chrome on ink (surface-2) with base text.
 * Brand statement + markup-only newsletter capture + real nav columns + social
 * row + baseline rule. Token-driven; pairs base text on the surface-2 ink bg.
 * ───────────────────────────────────────────────────────────────────────── */
.cp-site-footer {
  background: var(--wp--preset--color--surface-2, #2c271f);
  color: var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base, #f1eae0));
  padding-block: var(--wp--preset--spacing--60, 6.5rem) var(--wp--preset--spacing--40, 2.5rem);
  padding-inline: var(--wp--preset--spacing--40, 2.5rem);
  margin-top: var(--wp--preset--spacing--70, 9.5rem);
}

/* When a page closes on a full-bleed coloured band (the cta-band, or any
 * inverse/brand section as the last block), the footer's top gap would show as a
 * stray light stripe between that band and the ink footer. Collapse the gap so the
 * band flows straight into the footer. Pages that close on light content keep the
 * breathing room above. (:has() is baseline-supported.) */
main:has(> :last-child.has-primary-background-color) + .cp-site-footer,
main:has(> :last-child.has-surface-2-background-color) + .cp-site-footer,
main:has(> :last-child.has-contrast-background-color) + .cp-site-footer {
  margin-top: 0;
}

.cp-site-footer__inner {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: var(--wp--preset--spacing--50, 4rem);
  max-width: var(--wp--style--global--wide-size, 1240px);
  margin-inline: auto;
}

.cp-site-footer__brand-link {
  font-family: var(--wp--preset--font-family--heading, sans-serif);
  font-weight: 700;
  font-size: var(--wp--preset--font-size--x-large, 2rem);
  letter-spacing: -0.02em;
  color: var(--wp--preset--color--base, #f1eae0);
  text-decoration: none;
}

.cp-site-footer__statement {
  max-width: 42ch;
  margin-block: var(--wp--preset--spacing--20, 0.875rem) var(--wp--preset--spacing--30, 1.5rem);
  color: color-mix(in srgb, var(--wp--preset--color--base, #f1eae0) 78%, transparent);
  font-size: var(--wp--preset--font-size--medium, 1.125rem);
  line-height: 1.6;
}

.cp-site-footer__newsletter-row {
  display: flex;
  gap: var(--wp--preset--spacing--10, 0.5rem);
  max-width: 26rem;
}

.cp-site-footer__newsletter-input {
  flex: 1 1 auto;
  min-width: 0;
  padding-block: var(--wp--preset--spacing--20, 0.875rem);
  padding-inline: var(--wp--preset--spacing--30, 1.5rem);
  color: var(--wp--preset--color--base, #f1eae0);
  background: color-mix(in srgb, var(--wp--preset--color--base, #f1eae0) 8%, transparent);
  border: 1px solid color-mix(in srgb, var(--wp--preset--color--base, #f1eae0) 22%, transparent);
  border-radius: var(--wp--custom--radius--pill, 999px);
  font-family: var(--wp--preset--font-family--body, sans-serif);
  font-size: var(--wp--preset--font-size--small, 1rem);
}

.cp-site-footer__newsletter-input::placeholder {
  color: color-mix(in srgb, var(--wp--preset--color--base, #f1eae0) 50%, transparent);
}

.cp-site-footer__newsletter-btn {
  flex: 0 0 auto;
  padding-block: var(--wp--preset--spacing--20, 0.875rem);
  padding-inline: var(--wp--preset--spacing--30, 1.5rem);
  color: var(--wp--custom--color--on-accent, var(--wp--preset--color--base, #f1eae0));
  background: var(--wp--preset--color--accent, #965729);
  border: 0;
  border-radius: var(--wp--custom--radius--pill, 999px);
  font-family: var(--wp--preset--font-family--heading, sans-serif);
  font-weight: 600;
  font-size: var(--wp--preset--font-size--small, 1rem);
  cursor: pointer;
}

.cp-site-footer__newsletter-hint {
  margin-top: var(--wp--preset--spacing--10, 0.5rem);
  font-size: var(--wp--preset--font-size--small, 1rem);
  color: color-mix(in srgb, var(--wp--preset--color--base, #f1eae0) 60%, transparent);
}

.cp-site-footer__nav {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--wp--preset--spacing--40, 2.5rem);
}

.cp-site-footer__heading {
  margin: 0 0 var(--wp--preset--spacing--20, 0.875rem);
  font-family: var(--wp--preset--font-family--mono, monospace);
  font-size: var(--wp--preset--font-size--small, 1rem);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  /* sage-tint (light) on the ink footer — `secondary` sage fails WCAG AA at this
   * small size on surface-2 (~4.0:1); sage-tint clears it (~11:1). */
  color: var(--wp--custom--color--sage-tint, #d8e0cb);
}

.cp-site-footer__links,
.cp-site-footer__social {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: var(--wp--preset--spacing--10, 0.5rem);
}

.cp-site-footer__links a,
.cp-site-footer__social a {
  color: color-mix(in srgb, var(--wp--preset--color--base, #f1eae0) 82%, transparent);
  text-decoration: none;
  font-size: var(--wp--preset--font-size--small, 1rem);
  transition: color .2s ease;
}

.cp-site-footer__links a:hover,
.cp-site-footer__social a:hover {
  color: var(--wp--preset--color--base, #f1eae0);
}

.cp-site-footer__baseline {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: var(--wp--preset--spacing--20, 0.875rem);
  max-width: var(--wp--style--global--wide-size, 1240px);
  margin: var(--wp--preset--spacing--50, 4rem) auto 0;
  padding-top: var(--wp--preset--spacing--30, 1.5rem);
  border-top: 1px solid color-mix(in srgb, var(--wp--preset--color--base, #f1eae0) 18%, transparent);
}

.cp-site-footer__small {
  margin: 0;
  font-size: var(--wp--preset--font-size--small, 1rem);
  color: color-mix(in srgb, var(--wp--preset--color--base, #f1eae0) 60%, transparent);
}

/* Theme-aware footer foreground. The footer chrome above paints `base` as its light
 * text on the ink (surface-2) bg — correct while `base` is light, but a dark
 * direction (Atlas) has a dark `base`, which would vanish. Re-point every footer
 * text/affordance at the on-surface-2 band token (keeping each muted opacity), so the
 * footer stays legible in every direction. On Terra on-surface-2 === base → no change. */
.cp-site-footer__brand-link {
  color: var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base, #f1eae0)) !important;
}
/* The newsletter button sits in the footer band but carries its OWN accent fill,
 * so its label follows on-accent (legible on accent), not the on-surface-2 band
 * token. Without this it inherited base text and went illegible on a light accent. */
.cp-site-footer__newsletter-btn {
  color: var(--wp--custom--color--on-accent, var(--wp--preset--color--base, #f1eae0)) !important;
}
.cp-site-footer__statement {
  color: color-mix(in srgb, var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base, #f1eae0)) 78%, transparent) !important;
}
.cp-site-footer__links a,
.cp-site-footer__social a {
  color: color-mix(in srgb, var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base, #f1eae0)) 82%, transparent) !important;
}
.cp-site-footer__small,
.cp-site-footer__newsletter-hint {
  color: color-mix(in srgb, var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base, #f1eae0)) 60%, transparent) !important;
}
.cp-site-footer__newsletter-input {
  color: var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base, #f1eae0)) !important;
  background: color-mix(in srgb, var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base, #f1eae0)) 8%, transparent) !important;
  border-color: color-mix(in srgb, var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base, #f1eae0)) 22%, transparent) !important;
}
.cp-site-footer__newsletter-input::placeholder {
  color: color-mix(in srgb, var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base, #f1eae0)) 50%, transparent) !important;
}
.cp-site-footer__baseline {
  border-top-color: color-mix(in srgb, var(--wp--custom--color--on-surface-2, var(--wp--preset--color--base, #f1eae0)) 18%, transparent);
}

@media (max-width: 50rem) {
  .cp-site-footer__inner {
    grid-template-columns: 1fr;
  }

  /* Collapse the Explore/Connect columns so mono-caps headings don't wrap on phones */
  .cp-site-footer__nav {
    grid-template-columns: 1fr;
    gap: var(--wp--preset--spacing--40, 2.5rem);
  }
}

/* Fix 5 — Touch targets: give stacked nav + footer links a comfortable hit area
 * on coarse pointers without changing the visual text size. */
@media (pointer: coarse) {
  .cp-nav--stacked a,
  .cp-site-footer__links a,
  .cp-site-footer__social a {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
  }
}

/* The front page is a designed landing — the hero pattern carries the headline, so
 * suppress Sage's redundant page-header title on the home view. Inner content pages
 * (About, Services, …) keep their page title. */
body.home .page-header,
body.home .cp-page-header {
  display: none;
}

/* Terra page header — a designed full-bleed band so inner-page titles read as an
 * intentional header section rather than a lonely strip of body colour meeting the
 * first pattern. Sits on `base` so the whole top zone — sticky nav + title band —
 * is one continuous colour (no strip under the nav); the first content section then
 * carries the intentional tonal change, paced by the header's own visual mass. */
.cp-page-header {
  background-color: var(--wp--preset--color--base, #f1eae0);
  padding-block: var(--wp--preset--spacing--70) var(--wp--preset--spacing--60);
  padding-inline: var(--wp--preset--spacing--40);
}

.cp-page-header__inner {
  max-width: var(--wp--style--global--content-size, 780px);
  margin-inline: auto;
}

.cp-page-header__eyebrow {
  margin: 0 0 var(--wp--preset--spacing--20);
  font-family: var(--wp--preset--font-family--mono, ui-monospace, monospace);
  font-size: var(--wp--preset--font-size--small, 0.9375rem);
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--wp--preset--color--contrast-2, #5d564a);
}

.cp-page-header__title {
  margin: 0;
  font-family: var(--wp--preset--font-family--heading, sans-serif);
  font-size: var(--wp--preset--font-size--huge, clamp(2.75rem, 2rem + 4.5vw, 5rem));
  font-weight: 600;
  line-height: 1.02;
  letter-spacing: -0.015em;
  color: var(--wp--preset--color--contrast, #2c271f);
  text-wrap: balance;
}

.cp-page-header__lede {
  max-width: 46ch;
  margin: var(--wp--preset--spacing--30) 0 0;
  font-size: var(--wp--preset--font-size--large, 1.375rem);
  line-height: 1.5;
  color: var(--wp--preset--color--contrast-2, #5d564a);
  text-wrap: pretty;
}
