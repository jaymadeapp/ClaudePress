{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Section: Inverse",
  "slug": "section-inverse",
  "blockTypes": ["core/group", "core/columns"],
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--surface-2)",
      "text": "var(--wp--preset--color--base)"
    },
    "elements": {
      "heading": {
        "color": { "text": "var(--wp--preset--color--base)" }
      },
      "link": {
        "color": { "text": "var(--wp--custom--accent-on-dark)" },
        ":hover": {
          "color": { "text": "var(--wp--preset--color--base)" }
        }
      }
    }
  }
}
