# {{PROJECT_NAME}} — Bedrock .env.example
# Copy to .env and fill in real values. NEVER commit .env (two-lane invariant).
# Generate fresh salts at https://roots.io/salts.html

# Database
DB_NAME=db
DB_USER=db
DB_PASSWORD=db
# Optionally, you can use a data source name (DSN)
# When using a DSN, you can remove the DB_NAME, DB_USER, DB_HOST variables
# DATABASE_URL='mysql://db:db@127.0.0.1:3306/db'
DB_HOST=127.0.0.1
# DB_PREFIX=wp_

# Environment: development | staging | production
WP_ENV=development

# Site URLs (Bedrock serves WordPress from the /wp subdirectory)
WP_HOME=http://example.test
WP_SITEURL="${WP_HOME}/wp"

# Specify optional debug.log path
# WP_DEBUG_LOG=/path/to/debug.log

# Authentication unique keys and salts — replace ALL with values from
# https://roots.io/salts.html  (placeholders below; never use these in production)
AUTH_KEY='generateme'
SECURE_AUTH_KEY='generateme'
LOGGED_IN_KEY='generateme'
NONCE_KEY='generateme'
AUTH_SALT='generateme'
SECURE_AUTH_SALT='generateme'
LOGGED_IN_SALT='generateme'
NONCE_SALT='generateme'
