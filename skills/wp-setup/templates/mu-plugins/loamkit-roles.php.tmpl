<?php
/**
 * Plugin Name:  Loamkit Roles & Editor Lockdown
 * Description:  Registers a restricted client role and hardens the editor for
 *               safe client self-editing. Generated by Loamkit wp-setup.
 * Author:       Jakub Sládek
 * License:      MIT
 *
 * Text domain (rendered from resolved-config.json slug): {{TEXTDOMAIN}}
 *
 * NOTE: For full lockdown, also set the following in your Bedrock config
 * (config/application.php or environment config), NOT here:
 *
 *     Config::define( 'DISALLOW_FILE_EDIT', true );
 *     Config::define( 'DISALLOW_FILE_MODS', true );
 *
 * DISALLOW_FILE_EDIT disables the plugin/theme file editors; DISALLOW_FILE_MODS
 * also disables install/update of plugins and themes from the admin. This file
 * cannot set those constants reliably (it loads after they would take effect),
 * so they are documented here and belong in config.
 *
 * @package Loamkit
 */

declare( strict_types=1 );

namespace Loamkit\Roles;

if ( ! defined( 'ABSPATH' ) ) {
	exit;
}

/**
 * Slug used as text domain and role-key prefix (rendered by wp-setup).
 *
 * @var string
 */
const TEXTDOMAIN = '{{TEXTDOMAIN}}';

/**
 * Capabilities that must never be granted to the restricted client role or to
 * WooCommerce's shop_manager, because they let a user alter global theme
 * structure, templates or site-wide options.
 *
 * @return string[]
 */
function structural_caps(): array {
	return array(
		'edit_theme_options', // Customizer, menus, widgets, Site Editor global styles.
		'edit_themes',
		'edit_plugins',
		'edit_files',
		'install_themes',
		'install_plugins',
		'update_core',
		'update_plugins',
		'update_themes',
		'switch_themes',
	);
}

/**
 * Register the restricted client role on plugin activation / first load.
 *
 * The client can create and edit their own content (pages/posts/media) but
 * cannot touch theme structure, templates, global styles, plugins or other
 * users. Block/template structure is further constrained via templateLock /
 * contentOnly in the theme's patterns.
 *
 * @return void
 */
function register_client_role(): void {
	$role_key = TEXTDOMAIN . '_client';

	// Idempotent: remove and re-add so capability changes take effect on update.
	remove_role( $role_key );

	add_role(
		$role_key,
		__( 'Client Editor', 'loamkit' ),
		array(
			'read'                   => true,
			'upload_files'           => true,
			'edit_posts'             => true,
			'edit_published_posts'   => true,
			'edit_pages'             => true,
			'edit_published_pages'   => true,
			'delete_posts'           => true,
			'delete_published_posts' => true,
			'publish_posts'          => true,
			'publish_pages'          => true,
			// Explicitly denied structural capabilities (kept false for clarity).
			'edit_theme_options'     => false,
			'edit_themes'            => false,
			'edit_plugins'           => false,
			'switch_themes'          => false,
			'manage_options'         => false,
		)
	);
}

/**
 * On init, strip structural capabilities from the restricted client role and,
 * for WooCommerce e-shops, from the shop_manager role. Runs every load so it
 * survives role changes made by other plugins.
 *
 * @return void
 */
function enforce_role_restrictions(): void {
	$targets = array( TEXTDOMAIN . '_client' );

	// WooCommerce ships shop_manager; restrict it too when present.
	if ( get_role( 'shop_manager' ) ) {
		$targets[] = 'shop_manager';
	}

	foreach ( $targets as $role_key ) {
		$role = get_role( $role_key );

		if ( ! $role instanceof \WP_Role ) {
			continue;
		}

		foreach ( structural_caps() as $cap ) {
			if ( $role->has_cap( $cap ) ) {
				$role->remove_cap( $cap );
			}
		}
	}
}

/**
 * Hide the Site Editor and the theme/plugin file editor admin submenus for any
 * user who lacks edit_theme_options. Belt-and-suspenders alongside the
 * capability removal above and DISALLOW_FILE_EDIT.
 *
 * @return void
 */
function clean_admin_menu(): void {
	if ( current_user_can( 'edit_theme_options' ) ) {
		return;
	}

	// Block (Full Site) Editor.
	remove_submenu_page( 'themes.php', 'site-editor.php' );

	// Theme file editor and plugin file editor.
	remove_submenu_page( 'themes.php', 'theme-editor.php' );
	remove_submenu_page( 'plugins.php', 'plugin-editor.php' );

	// Customizer link (legacy).
	global $submenu;
	if ( isset( $submenu['themes.php'] ) && is_array( $submenu['themes.php'] ) ) {
		foreach ( $submenu['themes.php'] as $index => $item ) {
			if ( isset( $item[2] ) && false !== strpos( (string) $item[2], 'customize.php' ) ) {
				unset( $submenu['themes.php'][ $index ] );
			}
		}
	}
}

\register_activation_hook( __FILE__, __NAMESPACE__ . '\\register_client_role' );

// MU-plugins are not "activated"; ensure the role exists on every load (cheap, idempotent).
\add_action( 'init', __NAMESPACE__ . '\\register_client_role', 5 );
\add_action( 'init', __NAMESPACE__ . '\\enforce_role_restrictions', 20 );
\add_action( 'admin_menu', __NAMESPACE__ . '\\clean_admin_menu', 999 );
