add_action('woocommerce_after_add_to_cart_form', 'claudepress_woo_trust_badges', 20);

/**
 * Allowed-tags map for the decorative inline SVG icons emitted above.
 *
 * Restricts wp_kses() to harmless SVG shape elements and their geometry
 * attributes — no scripts, no event handlers, no external references.
 *
 * @return array<string, array<string, bool>>
 */
function claudepress_woo_svg_allowed(): array {
    $geometry = array(
        'd'                => true,
        'fill'             => true,
        'stroke'           => true,
        'stroke-width'     => true,
        'stroke-linecap'   => true,
        'stroke-linejoin'  => true,
        'cx'               => true,
        'cy'               => true,
        'r'                => true,
        'x'                => true,
        'y'                => true,
        'width'            => true,
        'height'           => true,
        'rx'               => true,
        'ry'               => true,
        'points'           => true,
        'viewBox'          => true,
    );

    return array(
        'path'    => $geometry,
        'circle'  => $geometry,
        'rect'    => $geometry,
        'line'    => $geometry,
        'polyline' => $geometry,
        'polygon' => $geometry,
        'g'       => $geometry,
    );
}

/**
 * Keep the single-product "Related products" row feeling full on a small catalog.
 *
 * WooCommerce relates strictly by shared category/tag, so a boutique catalogue (or a
 * fresh demo) often surfaces only one related item — a lone card stranded in a 4-up
 * grid reads as unfinished. When fewer than four related products are found, top the
 * row up with other recent published products (current product excluded), so the PDP
 * always closes on a balanced "you may also like" row.
 */
add_filter('woocommerce_output_related_products_args', function ($args) {
    $args['posts_per_page'] = 4;
    $args['columns']        = 4;

    return $args;
});

add_filter('woocommerce_related_products', function ($related, $product_id) {
    $related = array_values(array_unique(array_filter(array_map('intval', (array) $related))));

    if (count($related) >= 4 || ! function_exists('wc_get_products')) {
        return $related;
    }

    $fill = wc_get_products(array(
        'limit'   => 8,
        'status'  => 'publish',
        'exclude' => array_merge(array((int) $product_id), $related),
        'orderby' => 'date',
        'order'   => 'DESC',
        'return'  => 'ids',
    ));

    return array_slice(array_merge($related, array_map('intval', (array) $fill)), 0, 4);
}, 10, 2);

/**
 * Confine the sticky buy box (overlap-on-scroll fix). WooCommerce renders the
 * gallery, the .summary buy box, and the full-width tabs / related sections as
 * siblings inside div.product. A position:sticky .summary therefore takes
 * div.product as its sticky containing block and rides DOWN over the tabs /
 * related rows as the page scrolls — Chromium does not clip a sticky grid item
 * to its own grid row. Wrap just the gallery + summary in .cp-product-top so the
 * sticky element's containing block ends before those full-width sections.
 *
 * Markup-only (no template override): woo.css moves the two-column PDP grid onto
 * this wrapper. The open/close fire tightly around the summary — priority 1 on
 * before_single_product_summary (ahead of the sale flash at 10 and gallery at
 * 20) opens it; priority 1 on after_single_product_summary (ahead of the tabs at
 * 10) closes it. If the hooks ever stop matching, .cp-product-top is simply
 * absent and the gallery + summary stack vertically — a safe fallback, never an
 * overlap. Touches no cart / order / payment data.
 */
add_action('woocommerce_before_single_product_summary', function () {
    echo '<div class="cp-product-top">';
}, 1);

add_action('woocommerce_after_single_product_summary', function () {
    echo '</div>';
}, 1);
