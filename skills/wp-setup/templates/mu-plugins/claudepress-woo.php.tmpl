add_action('woocommerce_after_add_to_cart_form', 'claudepress_woo_trust_badges', 20);

/**
 * Allowed-tags map for the decorative inline SVG icons emitted above.
 *
 * Restricts wp_kses() to harmless SVG shape elements and their geometry
 * attributes — no scripts, no event handlers, no external references.
 *
 * @return array<string, array<string, bool>>
 */
function claudepress_woo_svg_allowed(): array {
    $geometry = array(
        'd'                => true,
        'fill'             => true,
        'stroke'           => true,
        'stroke-width'     => true,
        'stroke-linecap'   => true,
        'stroke-linejoin'  => true,
        'cx'               => true,
        'cy'               => true,
        'r'                => true,
        'x'                => true,
        'y'                => true,
        'width'            => true,
        'height'           => true,
        'rx'               => true,
        'ry'               => true,
        'points'           => true,
        'viewBox'          => true,
    );

    return array(
        'path'    => $geometry,
        'circle'  => $geometry,
        'rect'    => $geometry,
        'line'    => $geometry,
        'polyline' => $geometry,
        'polygon' => $geometry,
        'g'       => $geometry,
    );
}
