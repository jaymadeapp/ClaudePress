<?php
/**
 * Plugin Name: ClaudePress — WooCommerce
 * Description: Enables WooCommerce theme support (gallery zoom/lightbox/slider),
 *              declares HPOS (custom order tables) compatibility, and adds a few
 *              DISPLAY-ONLY designed conversion touches (USP bar, PDP trust
 *              badges, a sensible shop grid). Touches NO order, customer, cart
 *              or payment data. Part of the ClaudePress e-shop design system.
 * Author:      ClaudePress
 * License:     GPL-2.0-or-later
 *
 * Text domain (rendered from resolved-config.json slug): {{TEXTDOMAIN}}
 *
 * SAFETY: every hook below is presentational. Nothing here reads or writes
 * orders/customers/payments, alters cart totals, or registers a gateway. Markup
 * is escaped; styling lives in the theme's woo.css (token-classed, no inline CSS).
 */

if (! defined('ABSPATH')) {
    exit;
}

/*
 * Theme support: tell WooCommerce the active theme handles store templates, and
 * opt into the product-gallery enhancements (zoom / lightbox / slider).
 */
add_action('after_setup_theme', function () {
    add_theme_support('woocommerce');
    add_theme_support('wc-product-gallery-zoom');
    add_theme_support('wc-product-gallery-lightbox');
    add_theme_support('wc-product-gallery-slider');
});

/*
 * HPOS: declare this plugin compatible with WooCommerce custom order tables.
 * Guarded so it is harmless when WooCommerce (or its FeaturesUtil) is absent.
 */
add_action('before_woocommerce_init', function () {
    if (class_exists(\Automattic\WooCommerce\Utilities\FeaturesUtil::class)) {
        \Automattic\WooCommerce\Utilities\FeaturesUtil::declare_compatibility(
            'custom_order_tables',
            __FILE__,
            true
        );
    }
});

/*
 * Brand store stylesheet: enqueue the standalone woo.css AFTER WooCommerce's
 * own CSS so our token-driven rules win the cascade. The dependency on the
 * `woocommerce-general` handle (WooCommerce's main front-end stylesheet)
 * guarantees load order; filemtime() cache-busts on every redeploy. The file
 * is copied by the scaffold to <theme>/assets/css/woo.css and uses the global
 * theme.json CSS vars, so it needs no build step. Guarded so it is a no-op when
 * WooCommerce is absent or the file has not been installed.
 */
add_action('wp_enqueue_scripts', function () {
    if (! function_exists('is_woocommerce')) {
        return;
    }

    $rel = 'assets/css/woo.css';
    $abs = get_theme_file_path($rel);

    if (! file_exists($abs)) {
        return;
    }

    wp_enqueue_style(
        'claudepress-woo',
        get_theme_file_uri($rel),
        array('woocommerce-general'), // load AFTER WooCommerce core CSS
        filemtime($abs)               // cache-bust on redeploy
    );
}, 99);

/*
 * Designed shop grid: 3 columns, 9 products per page. Display-only filters.
 */
add_filter('loop_shop_columns', function () {
    return 3;
});

add_filter('loop_shop_per_page', function () {
    return 9;
});

/**
 * Drop WooCommerce's default sidebar (recent posts / archives / categories
 * widgets) — the Terra storefront is a clean full-width product grid, not a blog
 * with a sidebar. Display-only; touches no store data.
 */
add_action('init', function () {
    remove_action('woocommerce_sidebar', 'woocommerce_get_sidebar', 10);
}, 20);

/**
 * Constrained store container (the "missing margin" fix). WooCommerce's default
 * content wrapper outputs a bare <div id="primary" class="content-area"><main>
 * with NO max-width and NO horizontal padding, so the classic store templates
 * (shop archive, single product, my-account, classic cart/checkout) bleed
 * edge-to-edge — every other page on the site is constrained to the theme
 * wide-size by the header/footer chrome and the Blade content layout. Re-point
 * the wrapper to #primary.cp-store, which woo.css styles to the SAME wide-size +
 * spacing-40 inset as the chrome. We keep WooCommerce's expected #primary /
 * .site-main IDs/classes so any plugin or template targeting them still works.
 * Display-only — touches no cart/order/payment logic. Re-hooked on init (after
 * WooCommerce registers its defaults) at priority 20 so the remove() lands. */
add_action('init', function () {
    remove_action('woocommerce_before_main_content', 'woocommerce_output_content_wrapper', 10);
    remove_action('woocommerce_after_main_content', 'woocommerce_output_content_wrapper_end', 10);

    add_action('woocommerce_before_main_content', function () {
        echo '<div id="primary" class="content-area cp-store"><main id="main" class="site-main">';
    }, 10);

    add_action('woocommerce_after_main_content', function () {
        echo '</main></div>';
    }, 10);
}, 20);

/*
 * Branded placeholder image: when a product has no photo, WooCommerce shows a
 * gray "no image" box. Swap it for a bundled on-brand Terra product photo so
 * image-less (e.g. freshly-seeded) products still read as premium. Display-only
 * — touches no product/order data. Guarded with file_exists so it is a no-op
 * (WooCommerce keeps its own default) when the bundled image is absent.
 */
add_filter('woocommerce_placeholder_img_src', function ($src) {
    $rel = 'images/product-1.webp';

    if (file_exists(get_theme_file_path($rel))) {
        return get_theme_file_uri($rel);
    }

    return $src;
});

/**
 * Geist Mono eyebrow above the shop / category archive title — the Terra
 * signature at the top of the store header. Hooked on
 * woocommerce_before_main_content at priority 11: our content wrapper opens at
 * priority 10 and the archive H1 prints later inside archive-product.php, so
 * priority 11 lands the eyebrow at the very top of the store content, ABOVE the
 * "Shop" title. Guarded to shop / product-category / product-taxonomy archives
 * only so it never appears on the single product, cart, or account pages.
 *
 * Pure presentation: a single escaped, translatable line styled by
 * .cp-shop-eyebrow in woo.css. Touches no store data.
 *
 * @return void
 */
function claudepress_woo_shop_eyebrow(): void {
    if (! function_exists('is_shop') || ! function_exists('is_product_category')) {
        return;
    }

    $is_archive = is_shop() || is_product_category();

    if (function_exists('is_product_taxonomy')) {
        $is_archive = $is_archive || is_product_taxonomy();
    }

    if (! $is_archive) {
        return;
    }

    echo '<p class="cp-shop-eyebrow">' . esc_html__('Catalog', '{{TEXTDOMAIN}}') . '</p>';
}
add_action('woocommerce_before_main_content', 'claudepress_woo_shop_eyebrow', 11);

