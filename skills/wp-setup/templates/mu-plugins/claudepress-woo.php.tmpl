            'icon'  => '<path d="M3 7h11v8H3zM14 10h4l3 3v2h-7z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="7" cy="17" r="1.5" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="17" cy="17" r="1.5" fill="none" stroke="currentColor" stroke-width="1.5"/>',
        ),
        array(
            'label' => esc_html__('Easy 30-day returns', '{{TEXTDOMAIN}}'),
            'icon'  => '<path d="M4 12a8 8 0 1 1 2.3 5.6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M4 8v4h4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
        ),
        array(
            'label' => esc_html__('Secure payment', '{{TEXTDOMAIN}}'),
            'icon'  => '<rect x="5" y="10" width="14" height="9" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8 10V7a4 4 0 0 1 8 0v3" fill="none" stroke="currentColor" stroke-width="1.5"/>',
