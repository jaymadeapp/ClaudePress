            'label' => esc_html__('Fast dispatch', '{{TEXTDOMAIN}}'),
            'icon'  => '<path d="M3 7h11v8H3zM14 10h4l3 3v2h-7z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="7" cy="17" r="1.5" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="17" cy="17" r="1.5" fill="none" stroke="currentColor" stroke-width="1.5"/>',
        ),
        array(
            'label' => esc_html__('Hassle-free returns', '{{TEXTDOMAIN}}'),
