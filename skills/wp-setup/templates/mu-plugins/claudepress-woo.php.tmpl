add_action('woocommerce_before_shop_loop', 'claudepress_woo_usp_bar', 5);

/*
 * Shop toolbar wrapper. WooCommerce prints the result-count (priority 20) and the
 * sort dropdown (priority 30) as two separately-margined siblings on different
 * baselines — stock, unstyled. Wrap them in a single .cp-shop-toolbar row (opened
 * at priority 8, closed at priority 31) so woo.css can render them as one aligned
 * flex toolbar with a hairline divider. Markup-only; touches no store data. Sits
 * BELOW the USP bar (priority 5) and above the product grid.
 */
add_action('woocommerce_before_shop_loop', function () {
    echo '<div class="cp-shop-toolbar">';
}, 8);

add_action('woocommerce_before_shop_loop', function () {
    echo '</div>';
}, 31);

/**
 * Calm sale badge. WooCommerce ships a shouty "Sale!" flash (the universal
 * default-Woo tell). Swap the label for a calm, translatable "Sale" — DISPLAY
 * TEXT ONLY: this filters the badge markup, it does not read or change price,
 * discount, or any order/cart data.
 */
add_filter('woocommerce_sale_flash', function ($html, $post, $product) {
    return '<span class="onsale">' . esc_html__('Sale', '{{TEXTDOMAIN}}') . '</span>';
}, 10, 3);

