<?php
/**
 * Plugin Name:  ClaudePress Content Seeder
 * Description:  Idempotent, versioned WP-CLI seeder that populates the DEV/staging
 *               database with clearly-marked PLACEHOLDER content (pages + optional
 *               WooCommerce demo products). Content-as-code: flows UP via git and
 *               is create-if-absent, so it never clobbers content a client later
 *               edits in wp-admin. Generated by ClaudePress wp-setup.
 * Author:       Jakub Sládek
 * License:      MIT
 *
 * Text domain (rendered from resolved-config.json slug): {{TEXTDOMAIN}}
 *
 * TWO-LANE NOTE: This is the SAFE way to promote placeholder content to staging.
 * Do NOT push the DB up (the guard blocks it). Author content here instead, ship
 * it UP through git, and run `wp claudepress seed` as a post-deploy step on
 * dev/staging ONLY. See skills/wp-setup/reference/content-seeding.md.
 *
 * @package ClaudePress
 */

declare( strict_types=1 );

namespace ClaudePress\ContentSeed;

if ( ! defined( 'ABSPATH' ) ) {
	exit;
}

/**
 * Post-meta flag stamped on every seeded item. `unseed` deletes only items that
 * carry this flag, so real client content is never touched.
 *
 * @var string
 */
const SEED_META_KEY = '_claudepress_seeded';

/**
 * Post-meta key recording the STABLE seed key (the canonical slug or SKU an item
 * was first seeded under). Existence checks match on this FIRST, so renaming a
 * seeded page/product in wp-admin does not cause a duplicate on the next seed.
 *
 * @var string
 */
const SEED_KEY_META_KEY = '_claudepress_seed_key';

/**
 * Post-meta key recording the seed version that created an item. Bump
 * SEED_VERSION when the seed set changes; existing items are never updated.
 *
 * @var string
 */
const SEED_VERSION_META_KEY = '_claudepress_seed_version';

/**
 * Current seed version. Stamped onto newly-created items for traceability.
 *
 * @var string
 */
const SEED_VERSION = '1.0.0';

/*
 * Guard: only register WP-CLI commands when running under WP-CLI. Seeding on a
 * normal web request (page load) would be a bug — nothing here runs in the
 * browser.
 */
if ( ! ( defined( 'WP_CLI' ) && WP_CLI ) ) {
	return;
}

/**
 * Resolve the current Bedrock environment (production / staging / development).
 *
 * Reads the WP_ENV constant first, then the WP_ENV environment variable as a
 * fallback. Defaults to 'production' when unknown — fail-closed, so an
 * unconfigured environment is treated as production and refuses seeding.
 *
 * @return string Lower-cased environment name.
 */
function current_env(): string {
	if ( defined( 'WP_ENV' ) && is_string( WP_ENV ) && '' !== WP_ENV ) {
		return strtolower( (string) WP_ENV );
	}

	$env = getenv( 'WP_ENV' );

	if ( is_string( $env ) && '' !== $env ) {
		return strtolower( $env );
	}

	return 'production';
}

/**
 * Abort the current WP-CLI command if we are on production.
 *
 * Seeding is a dev/staging-only operation. Placeholder content must never land
 * in the production database, so this is a hard stop.
 *
 * @return void
 */
function assert_not_production(): void {
	if ( 'production' === current_env() ) {
		\WP_CLI::error( 'refusing to seed on production' );
	}
}

/**
 * Build the placeholder page set.
 *
 * Each entry is keyed by slug and clearly marked as placeholder copy so it is
 * obvious in wp-admin that the text must be replaced with real content.
 *
 * @return array<string, array{title: string, content: string}>
 */
function placeholder_pages(): array {
	$marker = '<!-- PLACEHOLDER — replace with real copy -->';

	return array(
		'home'     => array(
			'title'   => __( 'Home', '{{TEXTDOMAIN}}' ),
			'content' => $marker . "\n<p><strong>PLACEHOLDER — replace with real copy.</strong> "
				. 'Welcome to the site. Lorem ipsum dolor sit amet, consectetur adipiscing elit. '
				. 'This home page was created by the ClaudePress content seeder for preview only.</p>',
		),
		'about'    => array(
			'title'   => __( 'About', '{{TEXTDOMAIN}}' ),
			'content' => $marker . "\n<p><strong>PLACEHOLDER — replace with real copy.</strong> "
				. 'Tell visitors who you are. Lorem ipsum dolor sit amet, consectetur adipiscing '
				. 'elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>',
		),
		'services' => array(
			'title'   => __( 'Services', '{{TEXTDOMAIN}}' ),
			'content' => $marker . "\n<p><strong>PLACEHOLDER — replace with real copy.</strong> "
				. 'Describe what you offer. Ut enim ad minim veniam, quis nostrud exercitation '
				. 'ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>',
		),
		'contact'  => array(
			'title'   => __( 'Contact', '{{TEXTDOMAIN}}' ),
			'content' => $marker . "\n<p><strong>PLACEHOLDER — replace with real copy.</strong> "
				. 'Add your contact details here. Duis aute irure dolor in reprehenderit in '
				. 'voluptate velit esse cillum dolore eu fugiat nulla pariatur.</p>',
		),
	);
}

/**
 * Find a previously-seeded item by its STABLE seed key.
 *
 * Matches on SEED_KEY_META_KEY (the canonical slug/SKU an item was first seeded
 * under) so a seeded item that a client later RENAMED is still recognised as
 * already-seeded and is never duplicated on re-seed.
 *
 * @param string $post_type Post type to query (e.g. 'page', 'product').
 * @param string $seed_key  Canonical seed key (original slug or SKU).
 *
 * @return int The matching post ID, or 0 if none exists.
 */
function seeded_id_by_key( string $post_type, string $seed_key ): int {
	if ( '' === $seed_key ) {
		return 0;
	}

	$ids = get_posts(
		array(
			'post_type'      => $post_type,
			'post_status'    => 'any',
			'numberposts'    => 1,
			'fields'         => 'ids',
			'meta_key'       => SEED_KEY_META_KEY,
			'meta_value'     => $seed_key,
			'no_found_rows'  => true,
			'cache_results'  => false,
		)
	);

	$ids = array_map( 'intval', (array) $ids );

	return $ids ? (int) $ids[0] : 0;
}

/**
 * Create a single page if — and only if — it has not already been seeded.
 *
 * Create-if-absent: an existing page (whether seeded earlier or later edited by
 * a client) is left untouched and reported as skipped. Existence is checked by
 * the stable seed key FIRST (so a renamed seeded page is not duplicated), then
 * by current slug. Newly-created pages are stamped with the seeded + seed-key +
 * version meta so `unseed` can find them.
 *
 * @param string $slug    Desired page slug (also the canonical seed key).
 * @param string $title   Page title.
 * @param string $content Page content (placeholder copy).
 *
 * @return bool True if a page was created, false if it already existed or failed.
 */
function maybe_create_page( string $slug, string $title, string $content ): bool {
	$seed_key = sanitize_title( $slug );
	$slug     = $seed_key;

	if ( '' === $slug ) {
		return false;
	}

	// Skip if this seed key was already seeded (even if since renamed).
	if ( 0 !== seeded_id_by_key( 'page', $seed_key ) ) {
		return false;
	}

	// Skip if a page with this slug already exists — never overwrite.
	if ( null !== get_page_by_path( $slug, OBJECT, 'page' ) ) {
		return false;
	}

	$page_id = wp_insert_post(
		array(
			'post_title'   => sanitize_text_field( $title ),
			'post_name'    => $slug,
			'post_content' => wp_kses_post( $content ),
			'post_status'  => 'publish',
			'post_type'    => 'page',
		),
		true
	);

	if ( is_wp_error( $page_id ) || 0 === (int) $page_id ) {
		\WP_CLI::warning( sprintf( 'failed to create page "%s"', $slug ) );

		return false;
	}

	update_post_meta( (int) $page_id, SEED_META_KEY, 1 );
	update_post_meta( (int) $page_id, SEED_KEY_META_KEY, $seed_key );
	update_post_meta( (int) $page_id, SEED_VERSION_META_KEY, SEED_VERSION );

	return true;
}

/**
 * Build the demo WooCommerce product set.
 *
 * Keyed by SKU so create-if-absent can match on an existing product.
 *
 * @return array<string, array{name: string, price: string, description: string}>
 */
function demo_products(): array {
	return array(
		'cp-demo-1' => array(
			'name'        => __( 'Demo Product One', '{{TEXTDOMAIN}}' ),
			'price'       => '19.00',
			'description' => 'PLACEHOLDER — replace with real product copy. Lorem ipsum demo product.',
		),
		'cp-demo-2' => array(
			'name'        => __( 'Demo Product Two', '{{TEXTDOMAIN}}' ),
			'price'       => '29.00',
			'description' => 'PLACEHOLDER — replace with real product copy. Dolor sit amet demo product.',
		),
		'cp-demo-3' => array(
			'name'        => __( 'Demo Product Three', '{{TEXTDOMAIN}}' ),
			'price'       => '39.00',
			'description' => 'PLACEHOLDER — replace with real product copy. Consectetur demo product.',
		),
	);
}

/**
 * Create a single WooCommerce product if it has not already been seeded.
 *
 * Guarded so it is harmless on non-WooCommerce sites. Create-if-absent:
 * existence is checked by the stable seed key FIRST (so a renamed seeded
 * product is not duplicated), then by current SKU; an existing item is reported
 * as skipped and never modified.
 *
 * @param string $sku         Product SKU (also the canonical seed key).
 * @param string $name        Product name.
 * @param string $price       Regular price as a numeric string.
 * @param string $description Product description (placeholder copy).
 *
 * @return bool True if a product was created, false if it already existed or failed.
 */
function maybe_create_product( string $sku, string $name, string $price, string $description ): bool {
	if ( ! class_exists( 'WooCommerce' ) || ! function_exists( 'wc_get_product_id_by_sku' ) || ! class_exists( 'WC_Product_Simple' ) ) {
		return false;
	}

	$sku      = sanitize_text_field( $sku );
	$seed_key = $sku;

	if ( '' === $sku ) {
		return false;
	}

	// Skip if this seed key was already seeded (even if the SKU since changed).
	if ( 0 !== seeded_id_by_key( 'product', $seed_key ) ) {
		return false;
	}

	// Skip if a product with this SKU already exists — never overwrite.
	$existing_id = wc_get_product_id_by_sku( $sku );

	if ( $existing_id ) {
		return false;
	}

	try {
		$product = new \WC_Product_Simple();
		$product->set_name( sanitize_text_field( $name ) );
		$product->set_sku( $sku );
		$product->set_regular_price( $price );
		$product->set_description( wp_kses_post( $description ) );
		$product->set_status( 'publish' );
		$product->set_catalog_visibility( 'visible' );

		$product_id = $product->save();
	} catch ( \Exception $e ) {
		\WP_CLI::warning( sprintf( 'failed to create product "%s": %s', $sku, $e->getMessage() ) );

		return false;
	}

	if ( ! $product_id ) {
		\WP_CLI::warning( sprintf( 'failed to create product "%s"', $sku ) );

		return false;
	}

	update_post_meta( (int) $product_id, SEED_META_KEY, 1 );
	update_post_meta( (int) $product_id, SEED_KEY_META_KEY, $seed_key );
	update_post_meta( (int) $product_id, SEED_VERSION_META_KEY, SEED_VERSION );

	return true;
}

/**
 * Find every seeded item of a given post type.
 *
 * Matches on the SEED_META_KEY flag so only seeder-created items are returned.
 *
 * @param string $post_type Post type to query (e.g. 'page', 'product').
 *
 * @return int[] List of post IDs.
 */
function seeded_ids( string $post_type ): array {
	$ids = get_posts(
		array(
			'post_type'      => $post_type,
			'post_status'    => 'any',
			'numberposts'    => -1,
			'fields'         => 'ids',
			'meta_key'       => SEED_META_KEY,
			'meta_value'     => '1',
			'no_found_rows'  => true,
			'cache_results'  => false,
		)
	);

	return array_map( 'intval', (array) $ids );
}

/**
 * ClaudePress content-seeder WP-CLI commands.
 *
 * Registered under the `claudepress` namespace: `wp claudepress seed` and
 * `wp claudepress unseed`.
 */
class Command {

	/**
	 * Seed the DEV/staging database with placeholder content.
	 *
	 * Idempotent and create-if-absent: existing items (including ones a client
	 * later edited) are skipped, never overwritten. Refuses to run on production.
	 *
	 * Seeds placeholder pages (home, about, services, contact) and, when
	 * WooCommerce is active, a few demo products.
	 *
	 * ## EXAMPLES
	 *
	 *     wp claudepress seed
	 *
	 * @when after_wp_load
	 *
	 * @param string[] $args       Positional arguments (unused).
	 * @param string[] $assoc_args Associative arguments (unused).
	 *
	 * @return void
	 */
	public function seed( $args, $assoc_args ): void {
		unset( $args, $assoc_args );

		assert_not_production();

		$pages_created   = 0;
		$pages_skipped   = 0;
		$products_created = 0;
		$products_skipped = 0;

		foreach ( placeholder_pages() as $slug => $page ) {
			if ( maybe_create_page( (string) $slug, $page['title'], $page['content'] ) ) {
				++$pages_created;
				\WP_CLI::log( sprintf( 'created page: %s', $slug ) );
			} else {
				++$pages_skipped;
				\WP_CLI::log( sprintf( 'skipped page (exists): %s', $slug ) );
			}
		}

		if ( class_exists( 'WooCommerce' ) ) {
			foreach ( demo_products() as $sku => $product ) {
				if ( maybe_create_product( (string) $sku, $product['name'], $product['price'], $product['description'] ) ) {
					++$products_created;
					\WP_CLI::log( sprintf( 'created product: %s', $sku ) );
				} else {
					++$products_skipped;
					\WP_CLI::log( sprintf( 'skipped product (exists): %s', $sku ) );
				}
			}
		} else {
			\WP_CLI::log( 'WooCommerce not active — skipping demo products.' );
		}

		\WP_CLI::success(
			sprintf(
				'Seed complete on "%s". Pages: %d created, %d skipped. Products: %d created, %d skipped.',
				current_env(),
				$pages_created,
				$pages_skipped,
				$products_created,
				$products_skipped
			)
		);
	}

	/**
	 * Remove ONLY seeder-created placeholder content.
	 *
	 * Deletes items carrying the `_claudepress_seeded = 1` meta flag — placeholder
	 * pages (force-deleted) and demo products. Real, client-authored content is
	 * never touched. Refuses to run on production.
	 *
	 * ## EXAMPLES
	 *
	 *     wp claudepress unseed
	 *
	 * @when after_wp_load
	 *
	 * @param string[] $args       Positional arguments (unused).
	 * @param string[] $assoc_args Associative arguments (unused).
	 *
	 * @return void
	 */
	public function unseed( $args, $assoc_args ): void {
		unset( $args, $assoc_args );

		assert_not_production();

		$pages_removed    = 0;
		$products_removed = 0;

		foreach ( seeded_ids( 'page' ) as $page_id ) {
			$result = wp_delete_post( $page_id, true ); // Force delete (bypass trash).

			if ( false !== $result && null !== $result ) {
				++$pages_removed;
				\WP_CLI::log( sprintf( 'removed page #%d', $page_id ) );
			}
		}

		if ( class_exists( 'WooCommerce' ) ) {
			foreach ( seeded_ids( 'product' ) as $product_id ) {
				if ( function_exists( 'wc_get_product' ) ) {
					$product = wc_get_product( $product_id );

					if ( $product instanceof \WC_Product ) {
						$product->delete( true ); // Force delete.
						++$products_removed;
						\WP_CLI::log( sprintf( 'removed product #%d', $product_id ) );
						continue;
					}
				}

				$result = wp_delete_post( $product_id, true );

				if ( false !== $result && null !== $result ) {
					++$products_removed;
					\WP_CLI::log( sprintf( 'removed product #%d', $product_id ) );
				}
			}
		}

		\WP_CLI::success(
			sprintf(
				'Unseed complete on "%s". Removed %d placeholder pages and %d demo products.',
				current_env(),
				$pages_removed,
				$products_removed
			)
		);
	}
}

\WP_CLI::add_command( 'claudepress', __NAMESPACE__ . '\\Command' );
