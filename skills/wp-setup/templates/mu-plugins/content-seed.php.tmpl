			'title'   => __( 'Contact', '{{TEXTDOMAIN}}' ),
			'content' => $marker . "\n<p><strong>PLACEHOLDER — replace with real copy.</strong> "
				. 'Add your contact details here. Duis aute irure dolor in reprehenderit in '
