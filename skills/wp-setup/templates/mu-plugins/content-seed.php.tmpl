/**
 * Resolve a demo product category to its term ID, creating it create-if-absent.
 *
 * Matched and created by slug in the `product_cat` taxonomy via the term API
 * (never raw SQL). Guarded so it is harmless when WooCommerce's taxonomy is not
 * registered. Returns 0 on any failure so the caller can still create the
 * product without a category rather than aborting.
 *
 * @param string $slug Category slug (the canonical key).
 * @param string $name Category display name.
 *
 * @return int The term ID, or 0 on failure.
 */
function maybe_create_product_category( string $slug, string $name ): int {
	$slug = sanitize_title( $slug );

	if ( '' === $slug || ! taxonomy_exists( 'product_cat' ) ) {
		return 0;
	}

	$existing = get_term_by( 'slug', $slug, 'product_cat' );

	if ( $existing instanceof \WP_Term ) {
		return (int) $existing->term_id;
	}

	$result = wp_insert_term(
		sanitize_text_field( $name ),
		'product_cat',
		array( 'slug' => $slug )
	);

	if ( is_wp_error( $result ) || empty( $result['term_id'] ) ) {
		\WP_CLI::warning( sprintf( 'failed to create product category "%s"', $slug ) );

		return 0;
	}

	return (int) $result['term_id'];
}

/**
 * Create a single WooCommerce product if it has not already been seeded.
 *
 * Guarded so it is harmless on non-WooCommerce sites. Create-if-absent:
 * existence is checked by the stable seed key FIRST (so a renamed seeded
 * product is not duplicated), then by current SKU; an existing item is reported
 * as skipped and never modified.
 *
 * @param string $sku         Product SKU (also the canonical seed key).
 * @param string $name        Product name.
 * @param string $price       Regular price as a numeric string.
 * @param string $sale_price  Optional sale price as a numeric string ('' = none).
 * @param string $category    Optional demo product-category slug to assign ('' = none).
 * @param string $description Product description (placeholder copy).
 *
 * @return bool True if a product was created, false if it already existed or failed.
 */
function maybe_create_product( string $sku, string $name, string $price, string $sale_price, string $category, string $description ): bool {
	if ( ! class_exists( 'WooCommerce' ) || ! function_exists( 'wc_get_product_id_by_sku' ) || ! class_exists( 'WC_Product_Simple' ) ) {
		return false;
	}

	$sku      = sanitize_text_field( $sku );
	$seed_key = $sku;

	if ( '' === $sku ) {
		return false;
	}

	// Skip if this seed key was already seeded (even if the SKU since changed).
	if ( 0 !== seeded_id_by_key( 'product', $seed_key ) ) {
		return false;
	}

	// Skip if a product with this SKU already exists — never overwrite.
	$existing_id = wc_get_product_id_by_sku( $sku );

	if ( $existing_id ) {
		return false;
	}

	// Resolve (create-if-absent) the demo category via the term API — never raw SQL.
	$category_ids = array();

	if ( '' !== $category ) {
		$categories = demo_product_categories();
		$cat_name   = isset( $categories[ $category ] ) ? $categories[ $category ] : $category;
		$term_id    = maybe_create_product_category( $category, $cat_name );

		if ( 0 !== $term_id ) {
			$category_ids[] = $term_id;
		}
	}

	try {
		$product = new \WC_Product_Simple();
		$product->set_name( sanitize_text_field( $name ) );
		$product->set_sku( $sku );
		$product->set_regular_price( $price );

		if ( '' !== $sale_price ) {
			$product->set_sale_price( $sale_price );
		}

		if ( ! empty( $category_ids ) ) {
			$product->set_category_ids( $category_ids );
		}

		$product->set_description( wp_kses_post( $description ) );
		$product->set_status( 'publish' );
		$product->set_catalog_visibility( 'visible' );

		$product_id = $product->save();
	} catch ( \Exception $e ) {
		\WP_CLI::warning( sprintf( 'failed to create product "%s": %s', $sku, $e->getMessage() ) );

		return false;
	}

	if ( ! $product_id ) {
		\WP_CLI::warning( sprintf( 'failed to create product "%s"', $sku ) );

		return false;
	}

	update_post_meta( (int) $product_id, SEED_META_KEY, 1 );
	update_post_meta( (int) $product_id, SEED_KEY_META_KEY, $seed_key );
	update_post_meta( (int) $product_id, SEED_VERSION_META_KEY, SEED_VERSION );

	return true;
}

/**
 * Find every seeded item of a given post type.
 *
 * Matches on the SEED_META_KEY flag so only seeder-created items are returned.
 *
 * @param string $post_type Post type to query (e.g. 'page', 'product').
 *
 * @return int[] List of post IDs.
 */
function seeded_ids( string $post_type ): array {
	$ids = get_posts(
		array(
			'post_type'      => $post_type,
			'post_status'    => 'any',
			'numberposts'    => -1,
			'fields'         => 'ids',
			'meta_key'       => SEED_META_KEY,
			'meta_value'     => '1',
			'no_found_rows'  => true,
			'cache_results'  => false,
		)
	);

	return array_map( 'intval', (array) $ids );
}

/**
 * ClaudePress content-seeder WP-CLI commands.
 *
 * Registered under the `claudepress` namespace: `wp claudepress seed` and
 * `wp claudepress unseed`.
 */
class Command {

	/**
	 * Seed the DEV/staging database with placeholder content.
	 *
	 * Idempotent and create-if-absent: existing items (including ones a client
	 * later edited) are skipped, never overwritten. Refuses to run on production.
	 *
	 * Seeds placeholder pages (home, about, services, contact) and, when
	 * WooCommerce is active, a few demo products.
	 *
	 * ## EXAMPLES
	 *
	 *     wp claudepress seed
	 *
	 * @when after_wp_load
	 *
	 * @param string[] $args       Positional arguments (unused).
	 * @param string[] $assoc_args Associative arguments (unused).
	 *
	 * @return void
	 */
	public function seed( $args, $assoc_args ): void {
		unset( $args, $assoc_args );

		assert_not_production();

		$pages_created   = 0;
		$pages_skipped   = 0;
		$products_created = 0;
		$products_skipped = 0;

		foreach ( placeholder_pages() as $slug => $page ) {
			if ( maybe_create_page( (string) $slug, $page['title'], $page['content'] ) ) {
				++$pages_created;
				\WP_CLI::log( sprintf( 'created page: %s', $slug ) );
			} else {
				++$pages_skipped;
				\WP_CLI::log( sprintf( 'skipped page (exists): %s', $slug ) );
			}
		}

		if ( class_exists( 'WooCommerce' ) ) {
			// Ensure the demo categories exist (create-if-absent) before assigning.
			foreach ( demo_product_categories() as $cat_slug => $cat_name ) {
				maybe_create_product_category( (string) $cat_slug, $cat_name );
			}

			foreach ( demo_products() as $sku => $product ) {
				if ( maybe_create_product( (string) $sku, $product['name'], $product['price'], $product['sale_price'], $product['category'], $product['description'] ) ) {
					++$products_created;
					\WP_CLI::log( sprintf( 'created product: %s', $sku ) );
				} else {
					++$products_skipped;
					\WP_CLI::log( sprintf( 'skipped product (exists): %s', $sku ) );
				}
			}
		} else {
			\WP_CLI::log( 'WooCommerce not active — skipping demo products.' );
		}

		\WP_CLI::success(
			sprintf(
				'Seed complete on "%s". Pages: %d created, %d skipped. Products: %d created, %d skipped.',
				current_env(),
				$pages_created,
				$pages_skipped,
				$products_created,
				$products_skipped
			)
		);
	}

	/**
	 * Remove ONLY seeder-created placeholder content.
	 *
	 * Deletes items carrying the `_claudepress_seeded = 1` meta flag — placeholder
	 * pages (force-deleted) and demo products. Real, client-authored content is
	 * never touched. Refuses to run on production.
	 *
	 * ## EXAMPLES
	 *
	 *     wp claudepress unseed
	 *
	 * @when after_wp_load
	 *
	 * @param string[] $args       Positional arguments (unused).
	 * @param string[] $assoc_args Associative arguments (unused).
	 *
	 * @return void
	 */
	public function unseed( $args, $assoc_args ): void {
		unset( $args, $assoc_args );

		assert_not_production();

		$pages_removed    = 0;
		$products_removed = 0;

		foreach ( seeded_ids( 'page' ) as $page_id ) {
			$result = wp_delete_post( $page_id, true ); // Force delete (bypass trash).

			if ( false !== $result && null !== $result ) {
				++$pages_removed;
				\WP_CLI::log( sprintf( 'removed page #%d', $page_id ) );
			}
		}

		if ( class_exists( 'WooCommerce' ) ) {
			foreach ( seeded_ids( 'product' ) as $product_id ) {
				if ( function_exists( 'wc_get_product' ) ) {
					$product = wc_get_product( $product_id );

					if ( $product instanceof \WC_Product ) {
						$product->delete( true ); // Force delete.
						++$products_removed;
						\WP_CLI::log( sprintf( 'removed product #%d', $product_id ) );
						continue;
					}
				}

				$result = wp_delete_post( $product_id, true );

				if ( false !== $result && null !== $result ) {
					++$products_removed;
					\WP_CLI::log( sprintf( 'removed product #%d', $product_id ) );
				}
			}
		}

		\WP_CLI::success(
			sprintf(
				'Unseed complete on "%s". Removed %d placeholder pages and %d demo products.',
				current_env(),
				$pages_removed,
				$products_removed
			)
		);
	}
}

\WP_CLI::add_command( 'claudepress', __NAMESPACE__ . '\\Command' );
