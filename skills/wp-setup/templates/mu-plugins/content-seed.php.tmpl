<?php
/**
 * Plugin Name:  Loamkit Content Seeder
 * Description:  Idempotent, versioned WP-CLI seeder that populates the DEV/staging
 *               database with a FINISHED Terra preview: pages composed from the
 *               bundled block patterns (Home set as the static front page) and, for
 *               WooCommerce, demo products with real on-brand copy. Content-as-code:
 *               flows UP via git and is create-if-absent, so it never clobbers content
 *               a client later edits in wp-admin. Seeded items are tagged via meta so
 *               `unseed` can remove them. Generated by Loamkit wp-setup.
 * Author:       Jakub Sládek
 * License:      MIT
 *
 * Text domain (rendered from resolved-config.json slug): {{TEXTDOMAIN}}
 *
 * TWO-LANE NOTE: This is the SAFE way to promote placeholder content to staging.
 * Do NOT push the DB up (the guard blocks it). Author content here instead, ship
 * it UP through git, and run `wp loamkit seed` as a post-deploy step on
 * dev/staging ONLY. See skills/wp-setup/reference/content-seeding.md.
 *
 * @package Loamkit
 */

declare( strict_types=1 );

namespace Loamkit\ContentSeed;

if ( ! defined( 'ABSPATH' ) ) {
	exit;
}

/**
 * Post-meta flag stamped on every seeded item. `unseed` deletes only items that
 * carry this flag, so real client content is never touched.
 *
 * @var string
 */
const SEED_META_KEY = '_loamkit_seeded';

/**
 * Post-meta key recording the STABLE seed key (the canonical slug or SKU an item
 * was first seeded under). Existence checks match on this FIRST, so renaming a
 * seeded page/product in wp-admin does not cause a duplicate on the next seed.
 *
 * @var string
 */
const SEED_KEY_META_KEY = '_loamkit_seed_key';

/**
 * Post-meta key recording the seed version that created an item. Bump
 * SEED_VERSION when the seed set changes; existing items are never updated.
 *
 * @var string
 */
const SEED_VERSION_META_KEY = '_loamkit_seed_version';

/**
 * Current seed version. Stamped onto newly-created items for traceability.
 *
 * @var string
 */
const SEED_VERSION = '1.0.0';

/**
 * Attachment-meta key recording the bundled-image key (e.g. 'product-1') a
 * seeded media item was sideloaded from. Lets image sideloading be idempotent
 * (re-seed reuses the existing attachment) and lets `unseed` find media it
 * created. Attachments also carry SEED_META_KEY so cleanup matches them.
 *
 * @var string
 */
const SEED_IMAGE_KEY_META_KEY = '_loamkit_seed_image_key';

/**
 * Name of the navigation menu the seeder creates. `unseed` removes the menu by
 * this exact name, so a client-renamed menu is never touched. Create-if-absent:
 * an existing menu of this name is reused, never duplicated.
 *
 * @var string
 */
const SEED_NAV_MENU_NAME = 'Primary';

/**
 * Theme nav-menu location the seeded menu is assigned to. Matches the location
 * registered by Sage 11's app/setup.php (`register_nav_menus`).
 *
 * @var string
 */
const SEED_NAV_MENU_LOCATION = 'primary_navigation';

/*
 * Guard: only register WP-CLI commands when running under WP-CLI. Seeding on a
 * normal web request (page load) would be a bug — nothing here runs in the
 * browser.
 */
if ( ! ( defined( 'WP_CLI' ) && WP_CLI ) ) {
	return;
}

/**
 * Resolve the current Bedrock environment (production / staging / development).
 *
 * Reads the WP_ENV constant first, then the WP_ENV environment variable as a
 * fallback. Defaults to 'production' when unknown — fail-closed, so an
 * unconfigured environment is treated as production and refuses seeding.
 *
 * @return string Lower-cased environment name.
 */
function current_env(): string {
	if ( defined( 'WP_ENV' ) && is_string( WP_ENV ) && '' !== WP_ENV ) {
		return strtolower( (string) WP_ENV );
	}

	$env = getenv( 'WP_ENV' );

	if ( is_string( $env ) && '' !== $env ) {
		return strtolower( $env );
	}

	return 'production';
}

/**
 * Abort the current WP-CLI command if we are on production.
 *
 * Seeding is a dev/staging-only operation. Placeholder content must never land
 * in the production database, so this is a hard stop.
 *
 * @return void
 */
function assert_not_production(): void {
	if ( 'production' === current_env() ) {
		\WP_CLI::error( 'refusing to seed on production' );
	}
}

/**
 * Build the placeholder page set.
 *
 * Each entry is keyed by slug and clearly marked as placeholder copy so it is
 * obvious in wp-admin that the text must be replaced with real content.
 *
 * @return array<string, array{title: string, content: string}>
 */
function placeholder_pages(): array {
	// Compose each page from the bundled Terra block patterns (registered from the
	// theme's /patterns dir as loamkit/*) so a freshly-seeded site previews as
	// a FINISHED, designed Terra site — not lorem. The patterns carry editable demo
	// copy + bundled images; a wp:pattern reference expands at render and stays
	// fully editable in the block editor, so the client edits in place. Using real
	// patterns (instead of a "PLACEHOLDER — replace me" paragraph) also keeps the
	// preview clear of the design-review H2 placeholder hard-fail.
	$compose = static function ( array $slugs ): string {
		return implode( "\n", array_map(
			static function ( string $slug ): string {
				return '<!-- wp:pattern {"slug":"loamkit/' . $slug . '"} /-->';
			},
			$slugs
		) );
	};

	return array(
		'home'     => array(
			'title'   => __( 'Home', '{{TEXTDOMAIN}}' ),
			'content' => $compose( array( 'hero-organic', 'features-bento', 'image-band', 'feature-rows', 'testimonial-soft', 'cta-band' ) ),
		),
		'about'    => array(
			'title'   => __( 'About', '{{TEXTDOMAIN}}' ),
			'excerpt' => __( 'The studio, the hands and the slow craft behind every Terra piece.', '{{TEXTDOMAIN}}' ),
			'content' => $compose( array( 'image-band', 'feature-rows', 'testimonial-soft', 'cta-band' ) ),
		),
		'services' => array(
			'title'   => __( 'Services', '{{TEXTDOMAIN}}' ),
			'excerpt' => __( 'From bespoke commissions to wholesale — the ways we can work together.', '{{TEXTDOMAIN}}' ),
			'content' => $compose( array( 'features-bento', 'feature-rows', 'cta-band' ) ),
		),
		'contact'  => array(
			'title'   => __( 'Contact', '{{TEXTDOMAIN}}' ),
			'excerpt' => __( 'Commissions, wholesale, or just to say hello — we’d love to hear from you.', '{{TEXTDOMAIN}}' ),
			'content' => $compose( array( 'contact-split', 'cta-band' ) ),
		),
	);
}

/**
 * Make the seeded "Home" page the static front page.
 *
 * Create-if-absent: only acts when the site is still on the default "posts"
 * front, so it never overrides a client's explicit static-front choice. Without
 * this a fresh install shows the blog index ("Hello world!") at "/", burying the
 * designed Terra home. Dev/staging only (the seed command asserts not production).
 *
 * @return bool True if the front page was set, false if left as-is.
 */
function maybe_set_front_page(): bool {
	if ( 'page' === get_option( 'show_on_front' ) && (int) get_option( 'page_on_front' ) > 0 ) {
		return false; // A static front page is already configured — respect it.
	}

	$home = get_page_by_path( 'home', OBJECT, 'page' );

	if ( ! ( $home instanceof \WP_Post ) ) {
		return false;
	}

	update_option( 'show_on_front', 'page' );
	update_option( 'page_on_front', (int) $home->ID );

	return true;
}

/**
 * Find a previously-seeded item by its STABLE seed key.
 *
 * Matches on SEED_KEY_META_KEY (the canonical slug/SKU an item was first seeded
 * under) so a seeded item that a client later RENAMED is still recognised as
 * already-seeded and is never duplicated on re-seed.
 *
 * @param string $post_type Post type to query (e.g. 'page', 'product').
 * @param string $seed_key  Canonical seed key (original slug or SKU).
 *
 * @return int The matching post ID, or 0 if none exists.
 */
function seeded_id_by_key( string $post_type, string $seed_key ): int {
	if ( '' === $seed_key ) {
		return 0;
	}

	$ids = get_posts(
		array(
			'post_type'      => $post_type,
			'post_status'    => 'any',
			'numberposts'    => 1,
			'fields'         => 'ids',
			'meta_key'       => SEED_KEY_META_KEY,
			'meta_value'     => $seed_key,
			'no_found_rows'  => true,
			'cache_results'  => false,
		)
	);

	$ids = array_map( 'intval', (array) $ids );

	return $ids ? (int) $ids[0] : 0;
}

/**
 * Create a single page if — and only if — it has not already been seeded.
 *
 * Create-if-absent: an existing page (whether seeded earlier or later edited by
 * a client) is left untouched and reported as skipped. Existence is checked by
 * the stable seed key FIRST (so a renamed seeded page is not duplicated), then
 * by current slug. Newly-created pages are stamped with the seeded + seed-key +
 * version meta so `unseed` can find them.
 *
 * @param string $slug    Desired page slug (also the canonical seed key).
 * @param string $title   Page title.
 * @param string $content Page content (placeholder copy).
 *
 * @return bool True if a page was created, false if it already existed or failed.
 */
function maybe_create_page( string $slug, string $title, string $content, string $excerpt = '' ): bool {
	$seed_key = sanitize_title( $slug );
	$slug     = $seed_key;

	if ( '' === $slug ) {
		return false;
	}

	// Skip if this seed key was already seeded (even if since renamed).
	if ( 0 !== seeded_id_by_key( 'page', $seed_key ) ) {
		return false;
	}

	// Skip if a page with this slug already exists — never overwrite.
	if ( null !== get_page_by_path( $slug, OBJECT, 'page' ) ) {
		return false;
	}

	$page_id = wp_insert_post(
		array(
			'post_title'   => sanitize_text_field( $title ),
			'post_name'    => $slug,
			'post_content' => wp_kses_post( $content ),
			'post_excerpt' => sanitize_text_field( $excerpt ),
			'post_status'  => 'publish',
			'post_type'    => 'page',
		),
		true
	);

	if ( is_wp_error( $page_id ) || 0 === (int) $page_id ) {
		\WP_CLI::warning( sprintf( 'failed to create page "%s"', $slug ) );

		return false;
	}

	update_post_meta( (int) $page_id, SEED_META_KEY, 1 );
	update_post_meta( (int) $page_id, SEED_KEY_META_KEY, $seed_key );
	update_post_meta( (int) $page_id, SEED_VERSION_META_KEY, SEED_VERSION );

	return true;
}

