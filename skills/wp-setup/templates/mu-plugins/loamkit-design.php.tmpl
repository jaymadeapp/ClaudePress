<?php
/**
 * Plugin Name: Loamkit — Design
 * Description: Registers the Loamkit block-pattern category so the bundled
 *              theme-root /patterns appear grouped in the inserter. The patterns
 *              themselves are auto-registered by WordPress core from the active
 *              theme's /patterns directory — this only labels their category.
 * Author:      Loamkit
 * License:     GPL-2.0-or-later
 *
 * Part of the Loamkit design system. Safe to edit or remove; removing it only
 * drops the "Loamkit" category label (the patterns still register).
 */

if (! defined('ABSPATH')) {
    exit;
}

add_action('init', function () {
    if (function_exists('register_block_pattern_category')) {
        register_block_pattern_category(
            'loamkit',
            array('label' => __('Loamkit', '{{TEXTDOMAIN}}'))
        );
    }
});

/**
 * On-brand site icon (favicon). With no Site Icon set, browsers request
 * /favicon.ico and log a 404 — the kit's only console noise. Emit a tiny inline
 * SVG mark (a rounded tile in the active direction's `base` with a `primary`
 * blob) so the console stays clean and the tab is branded. Reads the live
 * theme.json palette so each direction (Terra/Atlas/…) gets its own colours.
 * Only fires when the client has NOT set their own Site Icon, so it never
 * overrides a real brand favicon. Display-only.
 */
add_action('wp_head', function () {
    if (function_exists('has_site_icon') && has_site_icon()) {
        return;
    }

    $hex = static function ($value, $fallback) {
        return (is_string($value) && preg_match('/^#[0-9a-fA-F]{3,8}$/', $value)) ? $value : $fallback;
    };

    $base    = '#f1eae0';
    $primary = '#3f4a2e';

    if (function_exists('wp_get_global_settings')) {
        $palette = wp_get_global_settings(array('color', 'palette'));
        $theme   = isset($palette['theme']) ? $palette['theme'] : (is_array($palette) ? $palette : array());

        foreach ((array) $theme as $color) {
            if (! isset($color['slug'], $color['color'])) {
                continue;
            }
            if ('base' === $color['slug']) {
                $base = $hex($color['color'], $base);
            }
            if ('primary' === $color['slug']) {
                $primary = $hex($color['color'], $primary);
            }
        }
    }

    $svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">'
        . '<rect width="32" height="32" rx="7" fill="' . $base . '"/>'
        . '<circle cx="16" cy="16" r="9" fill="' . $primary . '"/></svg>';

    printf(
        '<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%s">' . "\n",
        rawurlencode($svg)
    );
}, 5);

/**
 * Scroll-reveal motion layer + sticky-header scroll state. Reveals `.cp-reveal`
 * elements as they enter the viewport (adds `.is-in`), and flags the Terra site
 * header with `data-scrolled` once the page scrolls past the top so its hairline
 * border + solid backdrop fade in. The reveal CSS (in the theme) is fully gated
 * on prefers-reduced-motion; this script also bails out for reduced-motion users
 * and reveals everything immediately when IntersectionObserver is unavailable —
 * so content is never hidden. The header is a robust sticky/blur bar without any
 * JS; the scroll flag is a progressive enhancement only. Tiny, dependency-free,
 * footer-printed.
 */
add_action('wp_footer', function () {
    ?>
<script>
(function(){
  var els = document.querySelectorAll('.cp-reveal');
  if (els.length) {
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce || !('IntersectionObserver' in window)) {
      els.forEach(function(el){ el.classList.add('is-in'); });
    } else {
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if (e.isIntersecting){ e.target.classList.add('is-in'); io.unobserve(e.target); }
        });
      }, { rootMargin: '0px 0px -10% 0px', threshold: 0.12 });
      els.forEach(function(el){ io.observe(el); });
    }
  }

  var header = document.querySelector('[data-cp-header]');
  if (header) {
    var onScroll = function(){
      if (window.pageYOffset > 8) { header.setAttribute('data-scrolled', ''); }
      else { header.removeAttribute('data-scrolled'); }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
})();
</script>
    <?php
}, 99);
